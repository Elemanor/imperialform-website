---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Calendar, Clock, ArrowRight } from 'lucide-astro';

const blogPosts = [
  {
    title: "How to Measure Concrete Slump: Complete Testing Guide",
    excerpt: "Master the slump test - the crucial quality control measure that determines if concrete is workable enough for your project. Learn proper testing procedures and what the results mean.",
    category: "Testing & Quality",
    readTime: "10 min",
    date: "January 2024",
    url: "/blog/concrete-slump-test-guide"
  },
  {
    title: "OBC Foundation & Footing Dimensions Guide",
    excerpt: "Complete guide to Ontario Building Code requirements for foundation and footing dimensions. Includes standard sizes, adjustments for soil conditions, and Toronto-specific requirements.",
    category: "Building Codes",
    readTime: "15 min",
    date: "January 2024",
    url: "/blog/obc-foundation-dimensions-guide"
  },
  {
    title: "Frost Line Impact on Footings & Foundations",
    excerpt: "Toronto's 4-foot frost line is non-negotiable. Learn why proper depth matters, how frost heave destroys foundations, and proven protection strategies for our climate.",
    category: "Foundation Design",
    readTime: "12 min",
    date: "January 2024",
    url: "/blog/frost-line-impact-foundations"
  },
  {
    title: "Waterstop Application in Concrete Construction",
    excerpt: "Essential guide to waterstop selection and installation for concrete joints. Covers PVC, rubber, and hydrophilic types with detailed installation procedures.",
    category: "Waterproofing",
    readTime: "11 min",
    date: "January 2024",
    url: "/blog/waterstop-application-guide"
  },
  {
    title: "Concrete Floor Slab Specifications & Construction",
    excerpt: "Complete guide to foundation slab systems including 125mm crushed stone base, insulation, vapor barriers, and 75mm concrete with proper MPa ratings.",
    category: "Slab Construction",
    readTime: "16 min",
    date: "January 2024",
    url: "/blog/concrete-floor-slab-specifications"
  },
  {
    title: "Dampproofing vs Waterproofing Foundation Walls",
    excerpt: "Critical differences between dampproofing and waterproofing, OBC requirements, application methods, and when each is required for Toronto foundations.",
    category: "Moisture Protection",
    readTime: "14 min",
    date: "January 2024",
    url: "/blog/foundation-dampproofing-waterproofing"
  },
  {
    title: "200mm Concrete Wall & 200x450mm Footing Specifications",
    excerpt: "Standard specifications for 2-storey residential foundations including dimensions, reinforcement, construction sequence, and quality control requirements.",
    category: "Foundation Design",
    readTime: "18 min",
    date: "January 2024",
    url: "/blog/200mm-concrete-wall-specifications"
  },
  {
    title: "OBC Part 9 Rebar Requirements for Footings & Slabs",
    excerpt: "Complete guide to reinforcement requirements including bar sizes, placement, clear cover, lap splices, and common code violations in residential construction.",
    category: "Reinforcement",
    readTime: "20 min",
    date: "January 2024",
    url: "/blog/obc-rebar-requirements-footings-slabs"
  },
  {
    title: "Keyway in Footings: Purpose, Design & Construction",
    excerpt: "Essential guide to keyway construction for preventing foundation wall sliding. Covers dimensions, forming methods, and critical installation details.",
    category: "Foundation Details",
    readTime: "14 min",
    date: "January 2024",
    url: "/blog/keyway-footing-construction-guide"
  },
  {
    title: "Residential Column Requirements: Steel, Wood & Masonry",
    excerpt: "Complete guide to column sizing, installation, and load requirements per OBC Part 9. Covers adjustable steel columns, wood posts, and masonry columns.",
    category: "Structural Support",
    readTime: "16 min",
    date: "January 2024",
    url: "/blog/residential-column-requirements-guide"
  },
  {
    title: "Floors-on-Ground: Structural Requirements & Moisture Protection",
    excerpt: "Complete guide to OBC Part 9.16 requirements for concrete slabs on grade. Covers drainage, vapor barriers, insulation, and proper base preparation.",
    category: "Slab Construction",
    readTime: "18 min",
    date: "January 2024",
    url: "/blog/floors-on-ground-requirements"
  },
  {
    title: "Complete Foundation Design Guide: Soil, Structure & Code Requirements",
    excerpt: "Master OBC Part 9.15 requirements for residential footings and foundations. Covers soil bearing capacity, structural loads, and all foundation types.",
    category: "Foundation Design",
    readTime: "22 min",
    date: "January 2024",
    url: "/blog/foundation-design-comprehensive-guide"
  },
  {
    title: "Concrete Materials & Mix Design: The Science Behind Strong Foundations",
    excerpt: "Master concrete specifications, mix designs, and material requirements. Covers cement types, aggregates, admixtures, and quality control testing.",
    category: "Materials & Testing",
    readTime: "24 min",
    date: "January 2024",
    url: "/blog/concrete-materials-specifications-guide"
  },
  {
    title: "Excavation & Backfill: Safety, Methods, and Code Requirements",
    excerpt: "Complete guide to safe excavation practices, soil classification, shoring systems, and proper backfill techniques for residential construction.",
    category: "Site Work",
    readTime: "20 min",
    date: "January 2024",
    url: "/blog/excavation-backfill-safety-guide"
  },
  {
    title: "OBC Footing Requirements & Calculations: Complete Guide",
    excerpt: "Master OBC 9.15.3 footing design with detailed calculations, adjustment factors, and practical examples for Toronto residential construction.",
    category: "Foundation Design",
    readTime: "25 min",
    date: "January 2024",
    url: "/blog/footing-requirements-calculations-guide"
  }
];

const categories = [...new Set(blogPosts.map(post => post.category))];
---

<Layout title="Concrete Construction Blog | ImperialForm - Technical Guides & Building Codes">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Concrete Construction Blog
          </h1>
          <p class="text-xl text-gray-600">
            Technical guides, building codes, and expert insights from 39 years of Toronto concrete work
          </p>
        </div>
      </div>
    </section>

    <!-- Category Filter -->
    <section class="py-8 border-b">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap gap-3">
          <button class="px-4 py-2 bg-red-600 text-white rounded-lg font-semibold">
            All Posts
          </button>
          {categories.map(category => (
            <button class="px-4 py-2 bg-white text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
              {category}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {blogPosts.map(post => (
            <article class="bg-white rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
              <div class="p-6">
                <div class="flex items-center gap-4 mb-3 text-sm text-gray-500">
                  <span class="px-2 py-1 bg-gray-100 rounded text-xs font-semibold text-gray-700">
                    {post.category}
                  </span>
                  <div class="flex items-center gap-1">
                    <Clock class="w-3 h-3" />
                    <span>{post.readTime} read</span>
                  </div>
                </div>
                
                <h3 class="text-xl font-bold text-gray-900 mb-3">
                  <a href={post.url} class="hover:text-red-600 transition-colors">
                    {post.title}
                  </a>
                </h3>
                
                <p class="text-gray-600 mb-4 line-clamp-3">
                  {post.excerpt}
                </p>
                
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1 text-sm text-gray-500">
                    <Calendar class="w-3 h-3" />
                    <span>{post.date}</span>
                  </div>
                  
                  <a href={post.url} class="flex items-center gap-1 text-red-600 hover:text-red-700 font-semibold transition-colors">
                    Read More
                    <ArrowRight class="w-4 h-4" />
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter Signup -->
    <section class="py-16 bg-gray-900">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">
            Stay Updated on Concrete Best Practices
          </h2>
          <p class="text-gray-300 mb-8">
            Get monthly technical updates, code changes, and construction tips delivered to your inbox
          </p>
          <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
            <input 
              type="email" 
              placeholder="Enter your email"
              class="flex-1 px-4 py-3 rounded-lg text-gray-900"
              required
            />
            <button type="submit" class="px-6 py-3 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition-colors">
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- Topics Section -->
    <section class="py-12 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Popular Topics</h2>
        
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-3">Foundation Design</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• Footing dimensions and depths</li>
              <li>• Wall thickness requirements</li>
              <li>• Keyway construction</li>
              <li>• Frost protection</li>
            </ul>
          </div>
          
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-3">Building Codes</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• OBC Part 9 requirements</li>
              <li>• Reinforcement standards</li>
              <li>• Concrete specifications</li>
              <li>• Inspection requirements</li>
            </ul>
          </div>
          
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-3">Construction Methods</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• Slab construction layers</li>
              <li>• Waterproofing systems</li>
              <li>• Quality control testing</li>
              <li>• Installation procedures</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>