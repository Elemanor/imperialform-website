---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Building, Ruler, Shield } from 'lucide-astro';
---

<Layout title="200mm Concrete Wall & 200x450mm Footing | Standard 2-Storey House">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/blog" class="hover:text-red-600">Blog</a>
            <span>/</span>
            <span>Concrete Wall Specifications</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            200mm Concrete Wall & 200x450mm Footing with Key
          </h1>
          <p class="text-xl text-gray-600">
            Complete specifications for standard 2-storey residential foundations in Toronto
          </p>
          <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
            <span>Published: January 2024</span>
            <span>•</span>
            <span>18 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <article class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Introduction -->
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-xl text-gray-700 mb-8">
              The 200mm (8") poured concrete wall on a 200x450mm (8"x18") footing with keyway has become the 
              standard for 2-storey residential construction in Toronto. This combination provides the structural 
              capacity for typical loads while meeting Ontario Building Code requirements. After pouring thousands 
              of these foundations, here's everything contractors and homeowners need to know about this proven system.
            </p>

            <div class="bg-blue-50 rounded-lg p-6 mb-8 border-2 border-blue-400">
              <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                <Building class="w-5 h-5 text-blue-600" />
                Why 200mm Walls Are Standard
              </h3>
              <p class="text-gray-700">
                The 200mm wall thickness perfectly balances structural requirements, cost-effectiveness, and 
                constructability for typical 2-storey homes with 2.4m (8') basement walls and standard backfill 
                conditions. It's thick enough to handle lateral earth pressure while thin enough to be economical.
              </p>
            </div>
          </div>

          <!-- Complete Wall Specifications -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              200mm Foundation Wall Specifications
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">Dimensional Requirements</h3>
              <div class="grid md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Wall Dimensions:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Thickness: 200mm (8") nominal</li>
                    <li>• Tolerance: ±10mm</li>
                    <li>• Height: 2.4m (8') typical</li>
                    <li>• Above grade: 150-200mm minimum</li>
                    <li>• Below grade: 2.2-2.25m</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Load Capacity:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Supports: 2 storeys + roof</li>
                    <li>• Backfill: Up to 2.0m (6.5')</li>
                    <li>• Lateral pressure: 10 kPa typical</li>
                    <li>• Vertical load: 75 kN/m</li>
                    <li>• Safety factor: 2.5 minimum</li>
                  </ul>
                </div>
              </div>

              <h4 class="font-semibold text-gray-900 mb-3">Concrete Requirements:</h4>
              <div class="bg-gray-50 rounded-lg p-4">
                <ul class="space-y-2 text-gray-700">
                  <li>• Strength: 25 MPa minimum (we use 32 MPa)</li>
                  <li>• Slump: 140-160mm for pumping</li>
                  <li>• Air entrainment: 5-7% for freeze-thaw</li>
                  <li>• Maximum aggregate: 19mm (3/4")</li>
                  <li>• Water/cement ratio: 0.50 maximum</li>
                  <li>• Cement type: GU or MS for sulfate resistance</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Footing Specifications -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              200x450mm Footing with Keyway
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">Footing Dimensions</h3>
              <div class="grid md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Size & Depth:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Width: 450mm (18") minimum</li>
                    <li>• Depth: 200mm (8") minimum</li>
                    <li>• Below frost: 1.2m (4') in Toronto</li>
                    <li>• Projection: 125mm each side of wall</li>
                    <li>• Bottom elevation: Level ±20mm</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Keyway Details:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Width: 50mm (2") at top</li>
                    <li>• Depth: 40mm (1.5") minimum</li>
                    <li>• Shape: Trapezoidal (wider at base)</li>
                    <li>• Location: Centered on footing</li>
                    <li>• Purpose: Lateral load resistance</li>
                  </ul>
                </div>
              </div>

              <div class="bg-yellow-50 rounded-lg p-6 border border-yellow-400">
                <h4 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                  <Shield class="w-5 h-5 text-yellow-600" />
                  Why Use a Keyway?
                </h4>
                <p class="text-gray-700 mb-3">
                  The keyway creates a mechanical lock between the footing and wall, preventing the wall from 
                  sliding horizontally under lateral earth pressure. This is especially important for:
                </p>
                <ul class="space-y-1 text-gray-700">
                  <li>• Full-height backfill conditions</li>
                  <li>• Clay soils with expansion potential</li>
                  <li>• Areas with poor drainage</li>
                  <li>• Sloped lots with unbalanced fill</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Reinforcement Details -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Reinforcement Requirements</h2>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Wall Reinforcement</h3>
                <div class="space-y-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Vertical Bars:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• Size: 15M (16mm diameter)</li>
                      <li>• Spacing: 400mm (16") o.c.</li>
                      <li>• Location: Centered in wall</li>
                      <li>• Lap splice: 650mm minimum</li>
                      <li>• Hook into footing: 300mm</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Horizontal Bars:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• Size: 10M (11.3mm diameter)</li>
                      <li>• Spacing: 600mm (24") o.c.</li>
                      <li>• Both faces for 200mm wall</li>
                      <li>• Continuous at corners</li>
                      <li>• Extra bars at openings</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Footing Reinforcement</h3>
                <div class="space-y-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Longitudinal Bars:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• Minimum: 2-15M continuous</li>
                      <li>• Location: Bottom third</li>
                      <li>• Clear cover: 75mm bottom</li>
                      <li>• Side cover: 75mm minimum</li>
                      <li>• Lap splice: 650mm</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Corner Details:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• Extra 2-15M at corners</li>
                      <li>• Extend 1.5m each direction</li>
                      <li>• 90° hooks at ends</li>
                      <li>• Tie to main bars</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-lg p-6 mt-6">
              <h3 class="font-bold text-gray-900 mb-3">Clear Cover Requirements</h3>
              <div class="grid md:grid-cols-3 gap-4">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Footings:</h4>
                  <ul class="space-y-1 text-sm text-gray-700">
                    <li>• Bottom: 75mm</li>
                    <li>• Sides: 75mm</li>
                    <li>• Top: 40mm</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Walls (earth side):</h4>
                  <ul class="space-y-1 text-sm text-gray-700">
                    <li>• Below grade: 50mm</li>
                    <li>• Above grade: 40mm</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Walls (interior):</h4>
                  <ul class="space-y-1 text-sm text-gray-700">
                    <li>• All locations: 20mm</li>
                    <li>• With vapor barrier: 20mm</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Construction Sequence -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Construction Sequence</h2>
            
            <div class="space-y-4">
              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Excavation & Layout</h3>
                    <p class="text-gray-700">
                      Excavate to 1.3m depth (allowing for footing thickness). Over-excavate 600mm beyond wall 
                      line for working space. String lines for footing edges. Check elevations with laser level.
                    </p>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Footing Preparation</h3>
                    <p class="text-gray-700">
                      Compact subgrade to 95% SPD. Place 100mm crushed stone if required. Set footing forms 
                      450mm wide. Install 2-15M continuous bars on 75mm chairs. Form keyway with 2x2 beveled wood.
                    </p>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Pour Footings</h3>
                    <p class="text-gray-700">
                      Pour 25-32 MPa concrete. Vibrate thoroughly, especially around keyway form. Level top 
                      surface. Insert 15M dowels @ 400mm if no keyway. Remove keyway form after initial set.
                      Cure minimum 24 hours before wall forms.
                    </p>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Wall Form Setup</h3>
                    <p class="text-gray-700">
                      Clean footing surface and keyway. Snap chalk lines for wall position. Set up 200mm form 
                      system (aluminum or plywood). Install vertical bars @ 400mm, horizontal @ 600mm. Use 
                      spacers to maintain wall thickness. 
                    </p>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">5</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Wall Pour</h3>
                    <p class="text-gray-700">
                      Pour 32 MPa concrete in 1.2m lifts maximum. Vibrate each lift thoroughly - 5-15 seconds 
                      per insertion. Avoid over-vibration. Watch for form movement. Consolidate around openings.
                      Finish top level for sill plate.
                    </p>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">6</div>
                  <div>
                    <h3 class="font-bold text-gray-900 mb-2">Form Removal & Finishing</h3>
                    <p class="text-gray-700">
                      Strip forms after 24-48 hours (temperature dependent). Patch tie holes with non-shrink 
                      grout. Apply dampproofing/waterproofing from footing to grade. Install drainage board.
                      Cure 7 days before backfilling.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Load Calculations -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Typical Load Calculations</h2>
            
            <div class="bg-white rounded-lg p-8 border border-gray-200">
              <h3 class="font-bold text-gray-900 mb-4">2-Storey House Example</h3>
              
              <div class="grid md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Vertical Loads on Wall:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Roof load: 15 kN/m</li>
                    <li>• 2nd floor: 20 kN/m</li>
                    <li>• 1st floor: 20 kN/m</li>
                    <li>• Wall self-weight: 20 kN/m</li>
                    <li><strong>Total: 75 kN/m</strong></li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Bearing Pressure:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Load: 75 kN/m</li>
                    <li>• Footing width: 450mm</li>
                    <li>• Pressure: 167 kPa</li>
                    <li>• Soil capacity: 75 kPa (clay)</li>
                    <li><strong>Requires 450mm width ✓</strong></li>
                  </ul>
                </div>
              </div>

              <div class="bg-blue-50 rounded-lg p-4">
                <p class="text-gray-700">
                  <strong>Safety Check:</strong> 450mm footing on 75 kPa soil supports 33.75 kN/m. With safety 
                  factor of 2.5, allowable load is 84 kN/m > 75 kN/m actual. Design is adequate.
                </p>
              </div>
            </div>
          </div>

          <!-- Common Details -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Critical Construction Details</h2>
            
            <div class="space-y-6">
              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-3">Window & Door Openings</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Lintel requirement: For spans > 1.2m</li>
                  <li>• Extra reinforcement: 2-10M diagonal at corners</li>
                  <li>• Buck installation: Secure to prevent movement</li>
                  <li>• Sill detail: Slope for drainage, drip edge</li>
                  <li>• Minimum bearing: 200mm each side of opening</li>
                </ul>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-3">Beam Pockets</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Minimum bearing: 90mm for wood, 100mm for steel</li>
                  <li>• Pocket depth: Bearing + 12mm clearance</li>
                  <li>• Width: Beam width + 25mm total clearance</li>
                  <li>• Bearing plate: Required for concentrated loads</li>
                  <li>• Moisture protection: Dampproofing in pocket</li>
                </ul>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-3">Service Penetrations</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Sleeve installation: Before concrete pour</li>
                  <li>• Size: Pipe diameter + 50mm minimum</li>
                  <li>• Location: Avoid cutting rebar</li>
                  <li>• Sealing: Hydraulic cement or rubber boot</li>
                  <li>• Multiple penetrations: Minimum 300mm spacing</li>
                </ul>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-3">Cold Joints</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Location: Plan at 1/3 points of wall height</li>
                  <li>• Preparation: Roughen surface, remove laitance</li>
                  <li>• Bonding: Apply cement slurry before next pour</li>
                  <li>• Reinforcement: Continuous through joint</li>
                  <li>• Waterstop: Install for below-grade joints</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Quality Control -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Quality Control Checklist</h2>
            
            <div class="bg-green-50 rounded-lg p-8">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h3 class="font-bold text-gray-900 mb-3">Before Pour:</h3>
                  <ul class="space-y-2 text-gray-700">
                    <li>☐ Footing dimensions verified (450x200mm)</li>
                    <li>☐ Keyway properly formed</li>
                    <li>☐ Rebar spacing and size correct</li>
                    <li>☐ Clear cover maintained with chairs</li>
                    <li>☐ Forms plumb and braced</li>
                    <li>☐ Wall thickness verified (200mm)</li>
                    <li>☐ Opening dimensions checked</li>
                  </ul>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-3">During Pour:</h3>
                  <ul class="space-y-2 text-gray-700">
                    <li>☐ Concrete slump tested (140-160mm)</li>
                    <li>☐ Air content verified (5-7%)</li>
                    <li>☐ Cylinders taken for testing</li>
                    <li>☐ Proper vibration (5-15 seconds)</li>
                    <li>☐ Lifts not exceeding 1.2m</li>
                    <li>☐ No segregation or honeycombing</li>
                    <li>☐ Top of wall level (±10mm)</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Common Problems -->
          <div class="bg-red-50 rounded-lg p-8 mb-12 border-2 border-red-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Common Problems & Solutions</h2>
            
            <div class="space-y-4">
              <div>
                <h3 class="font-bold text-gray-900 mb-2">Keyway Not Centered</h3>
                <p class="text-gray-700 mb-2">
                  <strong>Problem:</strong> Wall not properly aligned with keyway center
                </p>
                <p class="text-gray-700">
                  <strong>Solution:</strong> Use string lines and plumb bob. Mark keyway center before setting forms. 
                  Offset reduces effectiveness by 50%.
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Insufficient Wall Thickness</h3>
                <p class="text-gray-700 mb-2">
                  <strong>Problem:</strong> Forms bow inward, wall less than 200mm
                </p>
                <p class="text-gray-700">
                  <strong>Solution:</strong> Use proper form ties and spacers. Check with gauge at multiple points. 
                  Walls under 190mm may require engineering review.
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Honeycombing at Base</h3>
                <p class="text-gray-700 mb-2">
                  <strong>Problem:</strong> Voids where wall meets footing/keyway
                </p>
                <p class="text-gray-700">
                  <strong>Solution:</strong> Ensure adequate slump (160mm). Vibrate thoroughly at keyway. 
                  Consider self-consolidating concrete for congested areas.
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Form Blowout</h3>
                <p class="text-gray-700 mb-2">
                  <strong>Problem:</strong> Forms fail during pour, concrete spills
                </p>
                <p class="text-gray-700">
                  <strong>Solution:</strong> Limit pour rate to 1.2m/hour. Check all ties and braces. 
                  Use proper form pressure calculations (35 kPa at base).
                </p>
              </div>
            </div>
          </div>

          <!-- Cost Analysis -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Cost Breakdown (per linear meter)</h2>
            
            <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
              <table class="w-full">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Component</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Material</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Labor</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Total</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold" colspan="4">450x200mm Footing with Key:</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Concrete (0.09 m³)</td>
                    <td class="py-3 px-4 text-gray-700">$18</td>
                    <td class="py-3 px-4 text-gray-700">-</td>
                    <td class="py-3 px-4 font-semibold">$18</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Rebar (2-15M)</td>
                    <td class="py-3 px-4 text-gray-700">$8</td>
                    <td class="py-3 px-4 text-gray-700">$4</td>
                    <td class="py-3 px-4 font-semibold">$12</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Forming & pour</td>
                    <td class="py-3 px-4 text-gray-700">$5</td>
                    <td class="py-3 px-4 text-gray-700">$25</td>
                    <td class="py-3 px-4 font-semibold">$30</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold" colspan="4">200mm Wall @ 2.4m height:</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Concrete (0.48 m³)</td>
                    <td class="py-3 px-4 text-gray-700">$96</td>
                    <td class="py-3 px-4 text-gray-700">-</td>
                    <td class="py-3 px-4 font-semibold">$96</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Rebar (vert. & horiz.)</td>
                    <td class="py-3 px-4 text-gray-700">$35</td>
                    <td class="py-3 px-4 text-gray-700">$20</td>
                    <td class="py-3 px-4 font-semibold">$55</td>
                  </tr>
                  <tr>
