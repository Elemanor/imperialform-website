---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Wrench, AlertTriangle, CheckCircle } from 'lucide-astro';
---

<Layout title="OBC Part 9 Rebar Requirements | Footings & Slabs Guide">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/blog" class="hover:text-red-600">Blog</a>
            <span>/</span>
            <span>Rebar Requirements</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Rebar Requirements for Footings & Slabs: OBC Part 9
          </h1>
          <p class="text-xl text-gray-600">
            Complete guide to reinforcement requirements for residential concrete per Ontario Building Code
          </p>
          <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
            <span>Published: January 2024</span>
            <span>•</span>
            <span>20 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <article class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Introduction -->
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-xl text-gray-700 mb-8">
              Proper reinforcement is the difference between concrete that lasts generations and concrete that 
              cracks within years. OBC Part 9 sets specific requirements for rebar in residential footings and 
              slabs - not suggestions, but mandatory minimums. After 39 years of placing rebar in Toronto 
              foundations, here's everything you need to know about getting it right.
            </p>

            <div class="bg-yellow-50 rounded-lg p-6 mb-8 border-2 border-yellow-400">
              <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                <AlertTriangle class="w-5 h-5 text-yellow-600" />
                Critical Update: OBC Changes
              </h3>
              <p class="text-gray-700">
                Recent OBC updates have increased reinforcement requirements for certain conditions. This guide 
                reflects current 2023-2024 requirements. Always verify with local building officials for the 
                latest amendments.
              </p>
            </div>
          </div>

          <!-- Rebar Basics -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Understanding Rebar Designations
            </h2>
            
            <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
              <table class="w-full">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Size</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Diameter</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Area</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Weight</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Common Use</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">10M</td>
                    <td class="py-3 px-4 text-gray-700">11.3mm</td>
                    <td class="py-3 px-4 text-gray-700">100mm²</td>
                    <td class="py-3 px-4 text-gray-700">0.785 kg/m</td>
                    <td class="py-3 px-4 text-gray-700">Slabs, temperature steel</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">15M</td>
                    <td class="py-3 px-4 text-gray-700">16.0mm</td>
                    <td class="py-3 px-4 text-gray-700">200mm²</td>
                    <td class="py-3 px-4 text-gray-700">1.570 kg/m</td>
                    <td class="py-3 px-4 text-gray-700">Footings, walls</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">20M</td>
                    <td class="py-3 px-4 text-gray-700">19.5mm</td>
                    <td class="py-3 px-4 text-gray-700">300mm²</td>
                    <td class="py-3 px-4 text-gray-700">2.355 kg/m</td>
                    <td class="py-3 px-4 text-gray-700">Heavy footings, grade beams</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">25M</td>
                    <td class="py-3 px-4 text-gray-700">25.2mm</td>
                    <td class="py-3 px-4 text-gray-700">500mm²</td>
                    <td class="py-3 px-4 text-gray-700">3.925 kg/m</td>
                    <td class="py-3 px-4 text-gray-700">Large footings, columns</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-6 mt-6">
              <p class="text-gray-700">
                <strong>Grade 400R:</strong> Standard reinforcement with 400 MPa yield strength. All residential 
                rebar must meet CSA G30.18 standards. The "M" designation means metric sizing.
              </p>
            </div>
          </div>

          <!-- Footing Reinforcement -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Footing Reinforcement Requirements (OBC 9.15.3.6)
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">Strip Footings (Wall Footings)</h3>
              
              <div class="grid md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Minimum Requirements:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• <strong>Bottom reinforcement:</strong> Required</li>
                    <li>• <strong>Minimum bars:</strong> 2-15M continuous</li>
                    <li>• <strong>Location:</strong> Bottom third of footing</li>
                    <li>• <strong>Clear cover:</strong> 75mm bottom, sides</li>
                    <li>• <strong>Lap splice:</strong> 600mm minimum</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">When More Is Required:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Footings > 600mm wide: Add bars</li>
                    <li>• Maximum spacing: 600mm</li>
                    <li>• Poor soil: Engineering required</li>
                    <li>• Stepped footings: Extra at steps</li>
                    <li>• Corners: 2 additional bars each way</li>
                  </ul>
                </div>
              </div>

              <div class="bg-blue-50 rounded-lg p-4">
                <h4 class="font-semibold text-gray-900 mb-2">Calculation Example:</h4>
                <p class="text-gray-700">
                  600mm wide footing: Minimum 2-15M (400mm² total)<br/>
                  900mm wide footing: Minimum 3-15M (600mm² total)<br/>
                  Rule: 0.002 x footing cross-sectional area
                </p>
              </div>
            </div>

            <div class="bg-white rounded-lg p-8 border-2 border-gray-300 mt-6">
              <h3 class="font-bold text-gray-900 mb-4">Pad Footings (Column Footings)</h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Square/Rectangular Pads:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Reinforcement in both directions</li>
                    <li>• Minimum: 15M @ 400mm o.c. each way</li>
                    <li>• Or minimum 0.002 x area</li>
                    <li>• Bottom placement with 75mm cover</li>
                  </ul>
                </div>
                
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Round Footings (Sonotubes):</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Minimum 3 vertical bars for posts</li>
                    <li>• 10M minimum for 200mm diameter</li>
                    <li>• 15M minimum for 300mm+ diameter</li>
                    <li>• Tied with spiral or rings</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Slab Reinforcement -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Slab-on-Grade Reinforcement (OBC 9.15.3.8)
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">When Reinforcement Is Required</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-green-50 rounded-lg p-6">
                  <h4 class="font-semibold text-gray-900 mb-3">Required For:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 mt-0.5" />
                      <span>Structural slabs (supporting loads)</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 mt-0.5" />
                      <span>Slabs over 5m in any dimension</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 mt-0.5" />
                      <span>Vehicle traffic areas (garages)</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 mt-0.5" />
                      <span>Areas with point loads</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 mt-0.5" />
                      <span>Heated floor slabs</span>
                    </li>
                  </ul>
                </div>
                
                <div class="bg-red-50 rounded-lg p-6">
                  <h4 class="font-semibold text-gray-900 mb-3">Not Required For:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <span class="text-red-600">✗</span>
                      <span>Residential basement slabs < 5m</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-red-600">✗</span>
                      <span>Sidewalks < 1.2m wide</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-red-600">✗</span>
                      <span>Patios on well-drained base</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-red-600">✗</span>
                      <span>Small shed slabs</span>
                    </li>
                  </ul>
                  <p class="text-sm text-gray-600 mt-3">
                    *But reinforcement still recommended for crack control
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg p-8 border-2 border-gray-300 mt-6">
              <h3 class="font-bold text-gray-900 mb-4">Reinforcement Options for Slabs</h3>
              
              <div class="space-y-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">1. Welded Wire Mesh (WWM)</h4>
                  <div class="bg-gray-50 rounded-lg p-4">
                    <ul class="space-y-2 text-gray-700">
                      <li>• <strong>Standard:</strong> 152x152 MW18.7/MW18.7 (6x6 W2.9/W2.9)</li>
                      <li>• <strong>Heavy duty:</strong> 152x152 MW25.8/MW25.8 (6x6 W4.0/W4.0)</li>
                      <li>• <strong>Placement:</strong> Middle to upper third of slab</li>
                      <li>• <strong>Support:</strong> Chairs @ 1.2m centers</li>
                      <li>• <strong>Overlap:</strong> 150mm minimum (one full square)</li>
                      <li>• <strong>Coverage:</strong> Full slab area to within 150mm of edges</li>
                    </ul>
                  </div>
                </div>

                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">2. Rebar Grid</h4>
                  <div class="bg-gray-50 rounded-lg p-4">
                    <ul class="space-y-2 text-gray-700">
                      <li>• <strong>Typical:</strong> 10M @ 450mm o.c. both ways</li>
                      <li>• <strong>Heavy loads:</strong> 10M @ 300mm o.c. both ways</li>
                      <li>• <strong>Minimum area:</strong> 0.002 x slab cross-section</li>
                      <li>• <strong>Placement:</strong> 50mm from top (75mm slab)</li>
                      <li>• <strong>Lap splice:</strong> 450mm for 10M bars</li>
                      <li>• <strong>Edge distance:</strong> 50mm minimum</li>
                    </ul>
                  </div>
                </div>

                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">3. Fiber Reinforcement</h4>
                  <div class="bg-gray-50 rounded-lg p-4">
                    <ul class="space-y-2 text-gray-700">
                      <li>• <strong>Synthetic fibers:</strong> 0.5-0.9 kg/m³</li>
                      <li>• <strong>Steel fibers:</strong> 20-40 kg/m³</li>
                      <li>• <strong>Purpose:</strong> Crack control, not structural</li>
                      <li>• <strong>OBC position:</strong> Supplement, not replacement</li>
                      <li>• <strong>Best for:</strong> Non-structural slabs</li>
                      <li>• <strong>Note:</strong> Doesn't meet code for structural reinforcement</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Wall Reinforcement -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Foundation Wall Reinforcement (OBC 9.15.4)
            </h2>
            
            <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
              <h3 class="text-lg font-bold text-gray-900 p-4 bg-gray-50">Minimum Reinforcement by Wall Type</h3>
              <table class="w-full">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Wall Type</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Vertical</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Horizontal</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr>
                    <td class="py-3 px-4 text-gray-700">200mm poured (8")</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 400mm o.c.</td>
                    <td class="py-3 px-4 text-gray-700">10M @ 600mm o.c.</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">250mm poured (10")</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 400mm o.c.</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 600mm o.c.</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">300mm poured (12")</td>
                    <td class="py-3 px-4 text-gray-700">20M @ 400mm o.c.</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 450mm o.c.</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">190mm block (8")</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 600mm o.c.</td>
                    <td class="py-3 px-4 text-gray-700">Joint reinf. @ 400mm</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">240mm block (10")</td>
                    <td class="py-3 px-4 text-gray-700">15M @ 400mm o.c.</td>
                    <td class="py-3 px-4 text-gray-700">Joint reinf. @ 400mm</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <div class="bg-yellow-50 rounded-lg p-6 mt-6">
              <h3 class="font-bold text-gray-900 mb-3">Additional Requirements:</h3>
              <ul class="space-y-2 text-gray-700">
                <li>• <strong>Corners:</strong> 2-15M vertical bars minimum each side</li>
                <li>• <strong>Openings:</strong> 2-10M around all openings</li>
                <li>• <strong>Top of wall:</strong> Continuous 15M bond beam</li>
                <li>• <strong>Intersections:</strong> 15M @ 600mm vertical</li>
                <li>• <strong>Lap splices:</strong> 40 bar diameters minimum</li>
              </ul>
            </div>
          </div>

          <!-- Clear Cover Requirements -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Clear Cover Requirements (OBC 9.15.4.2)
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">Minimum Concrete Cover to Reinforcement</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Cast Against Earth:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Footings: 75mm all surfaces</li>
                    <li>• Walls below grade: 75mm</li>
                    <li>• Slabs on ground: 75mm bottom</li>
                    <li>• Piers/caissons: 75mm</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Formed Concrete:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Exterior exposure: 40mm</li>
                    <li>• Interior dry: 20mm</li>
                    <li>• Slabs (top): 20mm minimum</li>
                    <li>• Beams/columns: 40mm</li>
                  </ul>
                </div>
              </div>

              <div class="bg-red-50 rounded-lg p-4 mt-6">
                <p class="text-gray-700">
                  <strong>Warning:</strong> Insufficient cover is the #1 cause of premature concrete failure. 
                  Exposed rebar rusts, expands, and cracks concrete. Always use proper chairs and spacers.
                </p>
              </div>
            </div>
          </div>

          <!-- Lap Splice Requirements -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Lap Splice Requirements
            </h2>
            
            <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
              <table class="w-full">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Bar Size</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Tension Lap</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Compression Lap</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Development Length</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">10M</td>
                    <td class="py-3 px-4 text-gray-700">450mm</td>
                    <td class="py-3 px-4 text-gray-700">300mm</td>
                    <td class="py-3 px-4 text-gray-700">350mm</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">15M</td>
                    <td class="py-3 px-4 text-gray-700">650mm</td>
                    <td class="py-3 px-4 text-gray-700">450mm</td>
                    <td class="py-3 px-4 text-gray-700">500mm</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">20M</td>
                    <td class="py-3 px-4 text-gray-700">850mm</td>
                    <td class="py-3 px-4 text-gray-700">600mm</td>
                    <td class="py-3 px-4 text-gray-700">650mm</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold">25M</td>
                    <td class="py-3 px-4 text-gray-700">1100mm</td>
                    <td class="py-3 px-4 text-gray-700">750mm</td>
                    <td class="py-3 px-4 text-gray-700">850mm</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-6 mt-6">
              <p class="text-gray-700">
                <strong>Rule of Thumb:</strong> 40 bar diameters for tension lap, 30 for compression. 
                Always stagger splices - never splice more than 50% of bars at same location.
              </p>
            </div>
          </div>

          <!-- Special Conditions -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Special Reinforcement Requirements</h2>
            
            <div class="space-y-6">
              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Crack Control in Slabs</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Temperature/Shrinkage Steel:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• Minimum: 0.002 x slab area</li>
                      <li>• Typical: 10M @ 450mm o.c.</li>
                      <li>• Maximum spacing: 450mm</li>
                      <li>• Both ways for square slabs</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Control Joint Spacing:</h4>
                    <ul class="space-y-1 text-gray-700">
                      <li>• 75mm slab: 2.7m maximum</li>
                      <li>• 100mm slab: 3.6m maximum</li>
                      <li>• 125mm slab: 4.5m maximum</li>
                      <li>• Depth: 1/4 slab thickness</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Heated Floor Slabs</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• WWM or 10M @ 300mm required above tubes</li>
                  <li>• Minimum 50mm cover above tubes</li>
                  <li>• No rebar contact with heating tubes</li>
                  <li>• Extra steel at manifold locations</li>
                  <li>• Consider expansion joints at 10m</li>
                </ul>
              </div>

              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Garage Slabs</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Minimum 100mm thickness</li>
                  <li>• WWM 152x152 MW25.8 (6x6 W4.0) required</li>
                  <li>• Or 10M @ 300mm both ways</li>
                  <li>• Thicken edges to 200mm</li>
                  <li>• Extra reinforcement at door openings</li>
                </ul>
              </div>

              <div class="bg-white rounded-lg p-6 border border-gray-200">
                <h3 class="font-bold text-gray-900 mb-4">Stepped Footings</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Extra 2-15M at each step</li>
                  <li>• Extend 600mm beyond step</li>
                  <li>• Vertical bars from lower to upper</li>
                  <li>• Maximum step height: 600mm</li>
                  <li>• Step length: 2x step height minimum</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Installation Best Practices -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Installation Best Practices</h2>
            
            <div class="bg-green-50 rounded-lg p-8">
              <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
                <Wrench class="w-5 h-5 text-green-600" />
                Proper Rebar Installation
              </h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Do:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>✓ Use proper chairs/spacers</li>
                    <li>✓ Tie all intersections</li>
                    <li>✓ Clean rust and oil from bars</li>
                    <li>✓ Support to prevent sagging</li>
                    <li>✓ Maintain specified spacing</li>
                    <li>✓ Check cover before pour</li>
                    <li>✓ Secure against movement</li>
                    <li>✓ Use bar caps on exposed ends</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Don't:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>✗ Walk on mesh during pour</li>
                    <li>✗ Pull mesh up through concrete</li>
                    <li>✗ Use rocks or wood for support</li>
                    <li>✗ Allow bars to touch ground</li>
                    <li>✗ Exceed maximum spacing</li>
                    <li>✗ Splice at high-stress points</li>
                    <li>✗ Use damaged or bent bars</li>
                    <li>✗ Forget corner bars</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Common Violations -->
          <div class="bg-red-50 rounded-lg p-8 mb-12 border-2 border-red-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Common OBC Violations We See</h2>
            
            <div class="space-y-4">
              <div>
                <h3 class="font-bold text-gray-900 mb-2">Missing Footing Reinforcement</h3>
                <p class="text-gray-700">
                  <strong>Violation:</strong> No rebar in residential footings<br/>
                  <strong>Code:</strong> Minimum 2-15M required in all footings<br/>
                  <strong>Result:</strong> Failed inspection, must chip out and add
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Insufficient Cover</h3>
                <p class="text-gray-700">
                  <strong>Violation:</strong> Rebar touching forms or ground<br/>
                  <strong>Code:</strong> 75mm cover required for footings<br/>
                  <strong>Result:</strong> Premature failure, concrete spalling
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Wrong Bar Size/Spacing</h3>
                <p class="text-gray-700">
                  <strong>Violation:</strong> Using 10M where 15M required<br/>
                  <strong>Code:</strong> Must meet minimum size and spacing<br/>
                  <strong>Result:</strong> Structural inadequacy, potential failure
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Improper Splices</h3>
                <p class="text-gray-700">
                  <strong>Violation:</strong> Inadequate lap length<br/>
                  <strong>Code:</strong> 40 bar diameters minimum<br/>
                  <strong>Result:</strong> Splice failure under load
                </p>
              </div>

              <div>
                <h3 class="font-bold text-gray-900 mb-2">Mesh on Ground</h3>
                <p class="text-gray-700">
                  <strong>Violation:</strong> WWM lying on vapor barrier<br/>
                  <strong>Code:</strong> Must be in upper third of slab<br/>
                  <strong>Result:</strong> No crack control benefit
                </p>
              </div>
            </div>
          </div>

