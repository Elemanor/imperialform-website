---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Droplets, Shield, AlertTriangle } from 'lucide-astro';
---

<Layout title="Foundation Dampproofing vs Waterproofing | Complete Guide">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/blog" class="hover:text-red-600">Blog</a>
            <span>/</span>
            <span>Foundation Moisture Protection</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Dampproofing vs Waterproofing Foundation Walls
          </h1>
          <p class="text-xl text-gray-600">
            Complete guide to moisture protection for 200mm concrete foundation walls
          </p>
          <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
            <span>Published: January 2024</span>
            <span>•</span>
            <span>14 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <article class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Introduction -->
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-xl text-gray-700 mb-8">
              Not all foundation moisture protection is created equal. The Ontario Building Code distinguishes 
              between dampproofing and waterproofing - two very different levels of protection with different 
              applications, materials, and costs. Understanding when you need each one can save thousands in 
              unnecessary upgrades or prevent catastrophic water damage. Here's what every Toronto homeowner 
              and contractor needs to know about protecting foundation walls from moisture.
            </p>

            <div class="bg-blue-50 rounded-lg p-6 mb-8 border-2 border-blue-400">
              <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                <Droplets class="w-5 h-5 text-blue-600" />
                The Critical Difference
              </h3>
              <p class="text-gray-700 mb-3">
                <strong>Dampproofing:</strong> Resists moisture in soil but NOT water under hydrostatic pressure. 
                Required minimum for all below-grade walls.
              </p>
              <p class="text-gray-700">
                <strong>Waterproofing:</strong> Resists water under pressure. Required where hydrostatic pressure 
                exists (high water table, poor drainage).
              </p>
            </div>
          </div>

          <!-- When Each is Required -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">OBC Requirements: When to Use Each</h2>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-green-50 rounded-lg p-6 border border-green-400">
                <h3 class="font-bold text-gray-900 mb-4">Dampproofing Required When:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-2">
                    <span class="text-green-600">✓</span>
                    Well-drained soils (sand, gravel)
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-green-600">✓</span>
                    Water table below footing level
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-green-600">✓</span>
                    Good surface drainage away from foundation
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-green-600">✓</span>
                    Functioning perimeter drainage
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-green-600">✓</span>
                    No history of water problems
                  </li>
                </ul>
              </div>
              
              <div class="bg-red-50 rounded-lg p-6 border border-red-400">
                <h3 class="font-bold text-gray-900 mb-4">Waterproofing Required When:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-2">
                    <span class="text-red-600">✓</span>
                    Clay soils with poor drainage
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-red-600">✓</span>
                    High water table (seasonal or permanent)
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-red-600">✓</span>
                    Hillside locations with water flow
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-red-600">✓</span>
                    Adjacent to water bodies
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-red-600">✓</span>
                    Known water pressure against walls
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Standard Wall Specifications -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              Standard 200mm Concrete Foundation Wall
            </h2>
            
            <div class="bg-white rounded-lg p-8 border-2 border-gray-300">
              <h3 class="font-bold text-gray-900 mb-4">Typical 2-Storey House Foundation</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Wall Specifications:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Thickness: 200mm (8")</li>
                    <li>• Height: 2.4m (8') typical</li>
                    <li>• Concrete: 25 MPa minimum</li>
                    <li>• Air entrainment: 5-7%</li>
                    <li>• W/C ratio: 0.50 maximum</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Reinforcement:</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Vertical: 15M @ 400mm o.c.</li>
                    <li>• Horizontal: 10M @ 600mm o.c.</li>
                    <li>• Corner bars: 2-15M each side</li>
                    <li>• Opening reinforcement: 2-10M</li>
                    <li>• Cover: 40mm minimum</li>
                  </ul>
                </div>
              </div>
              
              <div class="bg-yellow-50 rounded-lg p-4 mt-6">
                <p class="text-gray-700">
                  <strong>Note:</strong> This 200mm wall is suitable for 2.4m (8') of backfill with properly 
                  drained granular backfill. Clay backfill or poor drainage may require thicker walls.
                </p>
              </div>
            </div>
          </div>

          <!-- Dampproofing Methods -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Dampproofing Methods & Materials</h2>
            
            <div class="space-y-6">
              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-4">1. Bituminous Coating (Most Common)</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Application:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Spray or brush applied</li>
                      <li>• 2 coats minimum</li>
                      <li>• Coverage: 1.0 L/m² per coat</li>
                      <li>• Dry film thickness: 1mm minimum</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Standards:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• CAN/CGSB-37.2</li>
                      <li>• ASTM D449</li>
                      <li>• Cost: $8-12/m²</li>
                      <li>• Life: 20-30 years</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-4">2. Polymer-Modified Coating</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Application:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Spray or trowel applied</li>
                      <li>• Single coat possible</li>
                      <li>• Coverage: 2-3 L/m²</li>
                      <li>• Dry film: 1.5-2mm</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Standards:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• CAN/CGSB-37.8</li>
                      <li>• Better crack-bridging</li>
                      <li>• Cost: $12-18/m²</li>
                      <li>• Life: 30-40 years</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-gray-50 rounded-lg p-6">
                <h3 class="font-bold text-gray-900 mb-4">3. Parging with Coating</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Application:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• 6mm parging coat</li>
                      <li>• Type M or S mortar</li>
                      <li>• Bituminous coating over</li>
                      <li>• Good for rough walls</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Standards:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• CSA A179</li>
                      <li>• Traditional method</li>
                      <li>• Cost: $15-20/m²</li>
                      <li>• Life: 25-35 years</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Waterproofing Methods -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Waterproofing Systems</h2>
            
            <div class="space-y-6">
              <div class="bg-blue-50 rounded-lg p-6 border border-blue-400">
                <h3 class="font-bold text-gray-900 mb-4">1. Self-Adhered Membrane (Premium)</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">System Components:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Primer: Compatible with membrane</li>
                      <li>• Membrane: 1.5mm SBS modified</li>
                      <li>• Overlap: 100mm minimum</li>
                      <li>• Detailing: Corners, penetrations</li>
                      <li>• Protection: Drainage board</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Performance:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Withstands hydrostatic pressure</li>
                      <li>• Crack-bridging: 2mm</li>
                      <li>• Cost: $35-50/m²</li>
                      <li>• Life: 50+ years</li>
                      <li>• Standards: CGSB-37.50</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-blue-50 rounded-lg p-6 border border-blue-400">
                <h3 class="font-bold text-gray-900 mb-4">2. Liquid-Applied Membrane</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Application:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Spray/roller/trowel</li>
                      <li>• Multiple coats: 3mm total</li>
                      <li>• Reinforced at cracks</li>
                      <li>• Seamless application</li>
                      <li>• Inspection critical</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Performance:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Elastomeric properties</li>
                      <li>• 200-500% elongation</li>
                      <li>• Cost: $30-45/m²</li>
                      <li>• Life: 40+ years</li>
                      <li>• Standards: CAN/CGSB-37.58</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-blue-50 rounded-lg p-6 border border-blue-400">
                <h3 class="font-bold text-gray-900 mb-4">3. Bentonite Clay Systems</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Types:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Panels: 4.8mm composite</li>
                      <li>• Spray-applied: With polymer</li>
                      <li>• Trowel-grade: Thick application</li>
                      <li>• Self-healing properties</li>
                      <li>• Expands when wet</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Performance:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Works under pressure</li>
                      <li>• Seals small cracks</li>
                      <li>• Cost: $25-35/m²</li>
                      <li>• Life: 50+ years</li>
                      <li>• Requires confinement</li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="bg-blue-50 rounded-lg p-6 border border-blue-400">
                <h3 class="font-bold text-gray-900 mb-4">4. Crystalline Waterproofing</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Application:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Surface applied or admixture</li>
                      <li>• Penetrates concrete</li>
                      <li>• Forms crystals in pores</li>
                      <li>• Self-healing to 0.4mm</li>
                      <li>• Permanent treatment</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 mb-2">Performance:</h4>
                    <ul class="space-y-1 text-sm text-gray-700">
                      <li>• Becomes part of concrete</li>
                      <li>• Can't be damaged</li>
                      <li>• Cost: $15-25/m²</li>
                      <li>• Life: Permanent</li>
                      <li>• NSF 61 approved</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Installation Details -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Critical Installation Details</h2>
            
            <div class="bg-yellow-50 rounded-lg p-8 border-2 border-yellow-400">
              <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
                <AlertTriangle class="w-5 h-5 text-yellow-600" />
                Common Installation Requirements
              </h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Surface Preparation:</h4>
                  <ul class="space-y-1 text-gray-700">
                    <li>• Remove form ties, projections</li>
                    <li>• Fill voids, honeycombing</li>
                    <li>• Clean surface of oil, dust</li>
                    <li>• Cure concrete 7 days minimum</li>
                    <li>• Surface must be dry for most products</li>
                  </ul>
                </div>

                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Coverage Requirements:</h4>
                  <ul class="space-y-1 text-gray-700">
                    <li>• From footing to 150mm above grade</li>
                    <li>• Overlap footing by 150mm</li>
                    <li>• Seal all penetrations</li>
                    <li>• Detail inside/outside corners</li>
                    <li>• Cover cold joints completely</li>
                  </ul>
                </div>

                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Protection Board:</h4>
                  <ul class="space-y-1 text-gray-700">
                    <li>• Required for waterproofing membranes</li>
                    <li>• 6mm minimum thickness</li>
                    <li>• Protects during backfill</li>
                    <li>• Can incorporate drainage</li>
                    <li>• Extends to grade</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Drainage Requirements -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Essential Drainage Components</h2>
            
            <div class="bg-white rounded-lg p-8 border border-gray-200">
              <p class="text-gray-700 mb-6">
                Both dampproofing and waterproofing require proper drainage to function effectively:
              </p>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h3 class="font-bold text-gray-900 mb-3">Foundation Drainage:</h3>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Perforated pipe at footing level</li>
                    <li>• 100mm diameter minimum</li>
                    <li>• Slope 1% minimum to outlet</li>
                    <li>• Crushed stone surround 150mm</li>
                    <li>• Filter fabric wrap</li>
                  </ul>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-3">Backfill Requirements:</h3>
                  <ul class="space-y-2 text-gray-700">
                    <li>• Free-draining granular to 1m below grade</li>
                    <li>• Native soil cap (prevent surface water)</li>
                    <li>• Compact in 300mm lifts</li>
                    <li>• Grade away from foundation 2%</li>
                    <li>• No clay against wall</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Cost Comparison -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Cost Analysis: 200m² Foundation</h2>
            
            <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
              <table class="w-full">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">System</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Material</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Labor</th>
                    <th class="text-left py-3 px-4 font-semibold text-gray-900">Total Cost</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold" colspan="4">Dampproofing Options:</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Bituminous coating</td>
                    <td class="py-3 px-4 text-gray-700">$800</td>
                    <td class="py-3 px-4 text-gray-700">$1,600</td>
                    <td class="py-3 px-4 font-semibold">$2,400</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Polymer-modified</td>
                    <td class="py-3 px-4 text-gray-700">$1,500</td>
                    <td class="py-3 px-4 text-gray-700">$2,100</td>
                    <td class="py-3 px-4 font-semibold">$3,600</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700 font-semibold" colspan="4">Waterproofing Options:</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Self-adhered membrane</td>
                    <td class="py-3 px-4 text-gray-700">$4,000</td>
                    <td class="py-3 px-4 text-gray-700">$6,000</td>
                    <td class="py-3 px-4 font-semibold">$10,000</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Liquid membrane</td>
                    <td class="py-3 px-4 text-gray-700">$3,500</td>
                    <td class="py-3 px-4 text-gray-700">$5,500</td>
                    <td class="py-3 px-4 font-semibold">$9,000</td>
                  </tr>
                  <tr>
                    <td class="py-3 px-4 text-gray-700">Bentonite panels</td>
                    <td class="py-3 px-4 text-gray-700">$3,000</td>
                    <td class="py-3 px-4 text-gray-700">$4,000</td>
                    <td class="py-3 px-4 font-semibold">$7,000</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <p class="text-sm text-gray-600 mt-4">
              * Includes protection board and accessories. Drainage system additional $3,000-5,000.
            </p>
          </div>

          <!-- Toronto-Specific Considerations -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Toronto-Specific Considerations</h2>
            
            <div class="bg-blue-50 rounded-lg p-8">
              <h3 class="font-bold text-gray-900 mb-4">Local Conditions Requiring Waterproofing:</h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">High Water Table Areas:</h4>
                  <p class="text-gray-700">
                    • Toronto Islands, Beaches, Humber Bay<br/>
                    • Areas near Lake Ontario, Don River, Humber River<br/>
                    • Former marsh areas (much of downtown)
                  </p>
                </div>
                
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Clay Soil Regions:</h4>
                  <p class="text-gray-700">
                    • North York, Scarborough (glacial clay deposits)<br/>
                    • Poor drainage, seasonal water retention<br/>
                    • Requires waterproofing even with drainage
                  </p>
                </div>
                
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Ravine Properties:</h4>
                  <p class="text-gray-700">
                    • Natural water flow paths<br/>
                    • Spring-fed water sources<br/>
                    • Always requires full waterproofing
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Common Failures -->
          <div class="bg-red-50 rounded-lg p-8 mb-12 border-2 border-red-200">
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
              <AlertTriangle class="w-6 h-6 text-red-600" />
              Common Failure Points
            </h2>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h3 class="font-bold text-gray-900 mb-3">Dampproofing Failures:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Applied to wet/uncured concrete</li>
                  <li>• Insufficient coverage/holidays</li>
                  <li>• No protection at grade transition</li>
                  <li>• Damaged during backfill</li>
                  <li>• Wrong product for conditions</li>
                </ul>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-3">Waterproofing Failures:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li>• Poor surface preparation</li>
                  <li>• Inadequate overlap at seams</li>
                  <li>• Missing details at penetrations</li>
                  <li>• No protection board installed</li>
                  <li>• Drainage system failure</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Inspection Checklist -->
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Inspection Checklist</h2>
            
            <div class="bg-green-50 rounded-lg p-8">
              <h3 class="font-bold text-gray-900 mb-4">Before Backfill Inspection:</h3>
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Coverage Check:</h4>
                  <ul class="space-y-1 text-gray-700">
                    <li>☐ Complete coverage footing to grade</li>
                    <li>☐ All penetrations sealed</li>
                    <li>☐ Corners properly detailed</li>
                    <li>☐ Cold joints covered</li>
                    <li>☐ Tie holes sealed</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-3">Quality Check:</h4>
                  <ul class="space-y-1 text-gray-700">
