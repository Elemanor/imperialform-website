---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="Privacy Policy | Toronto Concrete">
  <Navigation />
  
  <main class="pt-24 pb-12">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-900 mb-6">Privacy Policy</h1>
        <p class="text-sm text-gray-600 mb-8">Effective Date: January 1, 2024</p>
        
        <div class="prose prose-gray max-w-none">
          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Information We Collect</h2>
            <p class="text-gray-700 mb-3">
              When you request a quote or contact us, we may collect:
            </p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Name and contact information (phone, email, address)</li>
              <li>Project details and requirements</li>
              <li>Property information relevant to concrete work</li>
              <li>Communication history for service quality</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">How We Use Your Information</h2>
            <p class="text-gray-700 mb-3">
              We use collected information to:
            </p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Provide accurate quotes and estimates</li>
              <li>Schedule and complete your concrete project</li>
              <li>Process payments and warranties</li>
              <li>Send project updates and maintenance reminders</li>
              <li>Improve our services based on feedback</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Information Sharing</h2>
            <p class="text-gray-700 mb-3">
              We never sell your personal information. We may share information with:
            </p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Our crew members involved in your project</li>
              <li>Material suppliers for delivery coordination</li>
              <li>Insurance providers for warranty claims</li>
              <li>Legal authorities when required by law</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Data Security</h2>
            <p class="text-gray-700">
              We protect your information using industry-standard security measures. Physical records 
              are stored securely at our office, and digital information is protected with appropriate 
              safeguards. However, no method is 100% secure, and we cannot guarantee absolute security.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Your Rights</h2>
            <p class="text-gray-700 mb-3">You have the right to:</p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Request access to your personal information</li>
              <li>Correct inaccurate information</li>
              <li>Request deletion of your information</li>
              <li>Opt-out of marketing communications</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Cookies</h2>
            <p class="text-gray-700">
              Our website uses cookies to improve user experience and analyze site traffic. You can 
              disable cookies in your browser settings, but some features may not function properly.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Changes to This Policy</h2>
            <p class="text-gray-700">
              We may update this privacy policy periodically. Changes will be posted on this page 
              with an updated effective date.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">Contact Us</h2>
            <p class="text-gray-700">
              For privacy-related questions or concerns:
            </p>
            <div class="mt-3 text-gray-700">
              <p>Toronto Concrete</p>
              <p>Phone: (416) 555-0199</p>
              <p>Email: privacy@torontoconcrete.ca</p>
              <p>Address: North York, Toronto, ON</p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>