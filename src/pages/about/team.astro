---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Award, Hammer, HardHat, Clock } from 'lucide-astro';
---

<Layout title="Our Team | Meet Toronto Concrete's Experts">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/about" class="hover:text-red-600">About</a>
            <span>/</span>
            <span>Our Team</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Meet Our Team
          </h1>
          <p class="text-xl text-gray-600">
            Three generations of concrete experts dedicated to quality and service
          </p>
        </div>
      </div>
    </section>

    <!-- Team Members -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Leadership -->
          <div class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Leadership</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <!-- Joe Jr. -->
              <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <img 
                  src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=600" 
                  alt="Joe Torretti Jr."
                  class="w-full h-64 object-cover"
                />
                <div class="p-6">
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Joe Torretti Jr.</h3>
                  <p class="text-red-600 font-semibold mb-4">President & CEO</p>
                  <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                    <div class="flex items-center gap-1">
                      <Clock class="w-4 h-4" />
                      <span>25+ Years</span>
                    </div>
                    <div class="flex items-center gap-1">
                      <Award class="w-4 h-4" />
                      <span>Master Contractor</span>
                    </div>
                  </div>
                  <p class="text-gray-700 mb-4">
                    Joe Jr. took over the family business from his father Giuseppe in 2005. Under his leadership, 
                    Toronto Concrete has grown from a small local operation to one of the GTA's most trusted contractors.
                  </p>
                  <p class="text-gray-700">
                    "My father taught me that reputation is everything. Every job we do, whether it's a small repair 
                    or a massive commercial project, gets the same attention to detail and commitment to quality."
                  </p>
                </div>
              </div>

              <!-- Michael -->
              <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <img 
                  src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=600" 
                  alt="Michael Torretti"
                  class="w-full h-64 object-cover"
                />
                <div class="p-6">
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Michael Torretti</h3>
                  <p class="text-red-600 font-semibold mb-4">VP Operations</p>
                  <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                    <div class="flex items-center gap-1">
                      <Clock class="w-4 h-4" />
                      <span>15+ Years</span>
                    </div>
                    <div class="flex items-center gap-1">
                      <HardHat class="w-4 h-4" />
                      <span>Project Management</span>
                    </div>
                  </div>
                  <p class="text-gray-700 mb-4">
                    Michael represents the third generation of the Torretti family in concrete. He brings modern 
                    techniques and technology while maintaining the traditional values of quality and service.
                  </p>
                  <p class="text-gray-700">
                    "I grew up on job sites watching my grandfather and father work. Now I'm proud to continue 
                    the tradition, ensuring every project meets our family's standards."
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Key Team Members -->
          <div class="mb-16">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Our Experts</h2>
            <div class="grid md:grid-cols-3 gap-6">
              <!-- Tony -->
              <div class="bg-white rounded-lg shadow-md p-6">
                <img 
                  src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400" 
                  alt="Tony Romano"
                  class="w-32 h-32 rounded-full mx-auto mb-4 object-cover"
                />
                <h3 class="text-xl font-bold text-gray-900 text-center mb-1">Tony Romano</h3>
                <p class="text-red-600 text-center mb-3">Head Foreman</p>
                <p class="text-sm text-gray-700 text-center mb-3">
                  30+ years experience. Specializes in decorative concrete and complex residential projects.
                </p>
                <div class="flex items-center justify-center gap-2 text-xs text-gray-600">
                  <Hammer class="w-4 h-4" />
                  <span>Master Craftsman</span>
                </div>
              </div>

              <!-- Maria -->
              <div class="bg-white rounded-lg shadow-md p-6">
                <img 
                  src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400" 
                  alt="Maria Santos"
                  class="w-32 h-32 rounded-full mx-auto mb-4 object-cover"
                />
                <h3 class="text-xl font-bold text-gray-900 text-center mb-1">Maria Santos</h3>
                <p class="text-red-600 text-center mb-3">Office Manager</p>
                <p class="text-sm text-gray-700 text-center mb-3">
                  10+ years with us. Your first point of contact, handles scheduling and customer service.
                </p>
                <div class="flex items-center justify-center gap-2 text-xs text-gray-600">
                  <Award class="w-4 h-4" />
                  <span>Customer Excellence</span>
                </div>
              </div>

              <!-- Frank -->
              <div class="bg-white rounded-lg shadow-md p-6">
                <img 
                  src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400" 
                  alt="Frank Chen"
                  class="w-32 h-32 rounded-full mx-auto mb-4 object-cover"
                />
                <h3 class="text-xl font-bold text-gray-900 text-center mb-1">Frank Chen</h3>
                <p class="text-red-600 text-center mb-3">Senior Estimator</p>
                <p class="text-sm text-gray-700 text-center mb-3">
                  15+ years experience. Provides accurate quotes and helps design your project.
                </p>
                <div class="flex items-center justify-center gap-2 text-xs text-gray-600">
                  <HardHat class="w-4 h-4" />
                  <span>Project Planning</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Our Crew -->
          <div class="bg-gray-50 rounded-lg p-8 mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Our Crew</h2>
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <div>
                <img 
                  src="https://images.unsplash.com/photo-1581094271901-8022df4466f9?w=600" 
                  alt="Our crew at work"
                  class="rounded-lg shadow-md"
                />
              </div>
              <div>
                <p class="text-gray-700 mb-4">
                  Beyond our leadership team, Toronto Concrete employs 20+ skilled concrete workers, many who've 
                  been with us for over a decade. Our crew includes:
                </p>
                <ul class="space-y-2 text-gray-700 mb-4">
                  <li>• Certified concrete finishers</li>
                  <li>• Equipment operators</li>
                  <li>• Form setters</li>
                  <li>• Decorative concrete specialists</li>
                  <li>• Foundation experts</li>
                </ul>
                <p class="text-gray-700">
                  We invest in ongoing training and safety certification for all our workers. Every crew member 
                  is covered by WSIB and follows strict safety protocols on every job site.
                </p>
              </div>
            </div>
          </div>

          <!-- Company Stats -->
          <div class="bg-red-600 text-white rounded-lg p-8">
            <h3 class="text-2xl font-bold mb-6 text-center">Our Team by the Numbers</h3>
            <div class="grid md:grid-cols-4 gap-6 text-center">
              <div>
                <div class="text-3xl font-bold mb-1">25+</div>
                <p class="text-sm">Team Members</p>
              </div>
              <div>
                <div class="text-3xl font-bold mb-1">250+</div>
                <p class="text-sm">Combined Years Experience</p>
              </div>
              <div>
                <div class="text-3xl font-bold mb-1">100%</div>
                <p class="text-sm">Safety Certified</p>
              </div>
              <div>
                <div class="text-3xl font-bold mb-1">3</div>
                <p class="text-sm">Generations Strong</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-900 text-white py-12">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Meet Us in Person</h2>
        <p class="text-xl mb-8 text-gray-300">
          Schedule a free consultation and see why Toronto trusts our team
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:416-555-0199" class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
            Call: (416) 555-0199
          </a>
          <a href="/get-quote" class="bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Schedule Consultation
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>