---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { ChevronDown, Phone } from 'lucide-astro';

const faqCategories = [
  {
    category: "General Questions",
    questions: [
      {
        q: "How much does concrete work cost in Toronto?",
        a: "Costs vary depending on the project type and size. Driveways typically range from $12-18 per square foot, patios from $15-25 per square foot, and repairs start around $500. We provide free, detailed quotes with no hidden fees."
      },
      {
        q: "Do you offer free estimates?",
        a: "Yes! We provide free on-site consultations and written estimates. We'll visit your property, assess the project, and provide a detailed quote with no obligation."
      },
      {
        q: "Are you licensed and insured?",
        a: "Yes, we're fully licensed in Ontario, carry $5 million liability insurance, and all our workers are covered by WSIB. We can provide proof of insurance upon request."
      },
      {
        q: "What areas do you serve?",
        a: "We serve all of Toronto and the Greater Toronto Area, including North York, Scarborough, Etobicoke, York, East York, Mississauga, Brampton, Vaughan, Richmond Hill, Markham, Pickering, Ajax, and Oakville."
      },
      {
        q: "How long have you been in business?",
        a: "Toronto Concrete has been serving the GTA since 1985 - that's 39 years of experience. We're a three-generation family business with thousands of satisfied customers."
      }
    ]
  },
  {
    category: "Project Planning",
    questions: [
      {
        q: "How long does a typical project take?",
        a: "Most residential driveways take 3-5 days from start to finish. Patios typically take 2-4 days. This includes excavation, forming, pouring, and initial curing. Weather can affect timelines."
      },
      {
        q: "Do I need a permit for concrete work?",
        a: "Most concrete projects in Toronto require permits, especially driveways and structural work. We handle all permit applications and approvals as part of our service - you don't need to worry about it."
      },
      {
        q: "When is the best time of year for concrete work?",
        a: "In Toronto, the ideal time is May through October when temperatures are consistently above 10°C. However, we can pour concrete year-round using winter techniques like heated concrete and insulated blankets."
      },
      {
        q: "How far in advance should I book?",
        a: "During peak season (summer), we recommend booking 2-3 weeks in advance. For spring and fall, 1-2 weeks is usually sufficient. We do offer emergency repair services year-round."
      },
      {
        q: "What preparation is needed before you arrive?",
        a: "Clear the area of vehicles and personal items. Mark any underground utilities (we can help arrange locates). That's it - we handle everything else including protecting surrounding areas."
      }
    ]
  },
  {
    category: "Technical Questions",
    questions: [
      {
        q: "How thick should a concrete driveway be?",
        a: "In Toronto, we pour residential driveways at minimum 4 inches thick, often 5-6 inches for heavy vehicles. We also use proper base preparation and reinforcement to prevent settling and cracking."
      },
      {
        q: "What's the difference between concrete and asphalt?",
        a: "Concrete lasts 30-50 years vs 15-20 for asphalt. Concrete handles Toronto's freeze-thaw cycles better, requires less maintenance, and offers more design options. Initial cost is higher but long-term value is better."
      },
      {
        q: "Will concrete crack?",
        a: "All concrete can develop small cracks over time, but proper installation minimizes this. We use control joints, proper reinforcement, and correct mix design to prevent problematic cracking. Our 25-year warranty covers structural issues."
      },
      {
        q: "Can you pour concrete over existing concrete?",
        a: "Sometimes, but it's rarely recommended. New concrete needs to be at least 2 inches thick and the old surface must be sound. Usually, removal and replacement is the better long-term solution."
      },
      {
        q: "What is stamped concrete?",
        a: "Stamped concrete is regular concrete imprinted with patterns to resemble stone, brick, slate, or other materials. It costs less than natural materials while offering similar aesthetics and better durability."
      }
    ]
  },
  {
    category: "Maintenance & Warranty",
    questions: [
      {
        q: "How do I maintain my concrete?",
        a: "Keep it clean with regular sweeping and occasional washing. Seal decorative concrete every 2-3 years. Avoid using rock salt in winter (use sand or calcium chloride). Fix small cracks promptly to prevent water damage."
      },
      {
        q: "What warranty do you offer?",
        a: "We provide a 25-year structural warranty on all work, 10-year surface warranty on decorative finishes, and 5-year workmanship guarantee. This is one of the best warranties in the industry."
      },
      {
        q: "How long before I can use my new driveway?",
        a: "You can walk on it after 24-48 hours. Wait 7 days before driving regular vehicles, 14 days for heavy vehicles. Full strength is reached at 28 days. We'll give you specific instructions based on weather conditions."
      },
      {
        q: "Should I seal my concrete?",
        a: "Yes, especially decorative concrete. Sealing protects against stains, weather, and wear. We seal all decorative work and offer resealing services. Standard concrete benefits from sealing but doesn't require it as frequently."
      },
      {
        q: "What about winter salt damage?",
        a: "Rock salt can damage concrete surfaces. We recommend using sand for traction or calcium chloride if de-icing is necessary. Our sealed surfaces have better salt resistance. Never use salt on concrete less than 1 year old."
      }
    ]
  },
  {
    category: "Pricing & Payment",
    questions: [
      {
        q: "How do you determine pricing?",
        a: "We price based on square footage, project complexity, site access, and finish type. Our quotes itemize all costs including materials, labor, equipment, and permits. No hidden fees ever."
      },
      {
        q: "Do you require a deposit?",
        a: "No, we don't require deposits for residential projects. Payment is due only when the work is complete and you're satisfied. For large commercial projects, we may arrange progress payments."
      },
      {
        q: "What payment methods do you accept?",
        a: "We accept cash, cheque, e-transfer, and credit cards (Visa/Mastercard). We can also arrange payment plans for larger projects. All prices include HST."
      },
      {
        q: "Can you match competitor quotes?",
        a: "We'll review any written quote from a licensed, insured competitor. While we don't always match the lowest price, we guarantee the best value - quality work that lasts with warranty protection."
      },
      {
        q: "Are there ways to reduce costs?",
        a: "Yes! Consider standard finishes instead of decorative, combine projects with neighbors for volume pricing, schedule during our slower season (late fall), or handle your own demolition/cleanup."
      }
    ]
  }
];
---

<Layout title="FAQ - Frequently Asked Questions | Toronto Concrete">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Frequently Asked Questions
          </h1>
          <p class="text-xl text-gray-600">
            Everything you need to know about concrete services in Toronto
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          {faqCategories.map((category, categoryIndex) => (
            <div class="mb-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-6 pb-2 border-b-2 border-red-600">
                {category.category}
              </h2>
              <div class="space-y-4">
                {category.questions.map((item, index) => (
                  <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    <button 
                      class="w-full px-6 py-4 text-left flex items-start justify-between gap-4 hover:bg-gray-50 transition-colors faq-trigger"
                      data-faq={`faq-${categoryIndex}-${index}`}
                    >
                      <h3 class="font-semibold text-gray-900 pr-4">{item.q}</h3>
                      <ChevronDown class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5 transition-transform faq-icon" />
                    </button>
                    <div class="hidden px-6 pb-4 text-gray-700 faq-content" id={`faq-${categoryIndex}-${index}`}>
                      <p>{item.a}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}

          <!-- Still Have Questions -->
          <div class="bg-red-600 text-white rounded-lg p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">Still Have Questions?</h2>
            <p class="mb-6">
              Can't find what you're looking for? Give us a call - we're happy to help!
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="tel:416-555-0199" class="bg-white text-red-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors inline-flex items-center justify-center gap-2">
                <Phone class="w-5 h-5" />
                (416) 555-0199
              </a>
              <a href="/contact" class="bg-red-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-800 transition-colors">
                Send Us a Message
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const faqTriggers = document.querySelectorAll('.faq-trigger');
  
  faqTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const faqId = trigger.getAttribute('data-faq');
      const content = document.getElementById(faqId);
      const icon = trigger.querySelector('.faq-icon');
      
      if (content) {
        content.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      }
    });
  });
</script>