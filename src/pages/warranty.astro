---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { Shield, CheckCircle, FileText, Phone } from 'lucide-astro';
---

<Layout title="25-Year Warranty | Toronto Concrete">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Our 25-Year Warranty
          </h1>
          <p class="text-xl text-gray-600">
            Industry-leading protection for your concrete investment
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- Left Content -->
          <div class="lg:col-span-2">
            <!-- Overview -->
            <div class="bg-white rounded-lg p-8 shadow-md mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">
                The Strongest Warranty in Toronto
              </h2>
              <p class="text-gray-700 mb-4">
                When we say we stand behind our work, we mean it. Every concrete project we complete 
                comes with our comprehensive 25-year warranty - the longest in the GTA. While other 
                contractors offer 1-5 year warranties (if any), we're confident enough in our work 
                to protect your investment for a quarter century.
              </p>
              <p class="text-gray-700 mb-4">
                This isn't some fine-print warranty that's impossible to claim. It's straightforward 
                protection that covers both materials and workmanship. If something goes wrong due to 
                our work, we fix it. Period.
              </p>
              <p class="text-gray-700">
                After 39 years in business, we've honored every single warranty claim. That's how 
                we've built our reputation and why families keep coming back generation after generation.
              </p>
            </div>

            <!-- What's Covered -->
            <div class="bg-green-50 rounded-lg p-8 mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <CheckCircle class="w-6 h-6 text-green-600" />
                What Our Warranty Covers
              </h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">Structural Issues</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Major cracking beyond normal hairline cracks
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Excessive settling or sinking
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Structural failure or collapse
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Separation from existing structures
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">Surface Defects</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Premature surface deterioration
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Spalling or flaking beyond normal wear
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Color fading (decorative concrete)
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Pattern wear (stamped concrete)
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">Workmanship</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Improper slope causing pooling water
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Incorrect joint placement
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Poor finish quality
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Installation defects
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">Foundation Work</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Waterproofing failure
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Crack repair failure
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Underpinning issues
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-green-600 mt-1">✓</span>
                      Drainage system failure
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- What's Not Covered -->
            <div class="bg-red-50 rounded-lg p-8 mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">
                Warranty Exclusions
              </h3>
              <p class="text-gray-700 mb-4">
                Our warranty is comprehensive, but like all warranties, it has reasonable exclusions:
              </p>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Normal wear and tear:</strong> Minor surface wear from regular use</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Acts of nature:</strong> Damage from earthquakes, floods, or extreme weather</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Abuse or misuse:</strong> Damage from heavy equipment not disclosed at time of installation</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Chemical damage:</strong> From de-icing salts or chemicals (unless sealed)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Modifications:</strong> Any alterations made by others after our installation</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Ground movement:</strong> Due to tree roots, soil conditions beyond our control</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600 mt-1">•</span>
                  <span><strong>Minor cracks:</strong> Hairline cracks are normal in concrete</span>
                </li>
              </ul>
            </div>

            <!-- How to Claim -->
            <div class="bg-gray-50 rounded-lg p-8 mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">
                How to Make a Warranty Claim
              </h3>
              <div class="space-y-4">
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Contact Us</h4>
                    <p class="text-gray-600">Call (416) 555-0199 or email warranty@torontoconcrete.ca with your project details</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Free Inspection</h4>
                    <p class="text-gray-600">We'll schedule a site visit within 48 hours to assess the issue</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Warranty Determination</h4>
                    <p class="text-gray-600">We'll determine if the issue is covered and provide a written response</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Free Repair</h4>
                    <p class="text-gray-600">If covered, we repair at no cost to you, usually within 1 week</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Lifetime Warranty Option -->
            <div class="bg-gradient-to-r from-yellow-50 to-orange-50 rounded-lg p-8 border-2 border-yellow-400">
              <h3 class="text-2xl font-bold text-gray-900 mb-4">
                <Shield class="inline w-6 h-6 text-yellow-600 mr-2" />
                Lifetime Warranty Available
              </h3>
              <p class="text-gray-700 mb-4">
                For foundation waterproofing and certain repair work, we offer an optional lifetime warranty 
                upgrade. This transferable warranty stays with your home forever, adding value and peace of mind.
              </p>
              <ul class="space-y-2 text-gray-700 mb-4">
                <li>• Covers original owner and all future owners</li>
                <li>• No time limit - valid for life of the structure</li>
                <li>• Adds significant value to your property</li>
                <li>• Small one-time upgrade fee</li>
              </ul>
              <p class="text-sm text-gray-600">
                Ask about lifetime warranty options when getting your quote.
              </p>
            </div>
          </div>

          <!-- Right Sidebar -->
          <div class="lg:col-span-1">
            <!-- Quick Contact -->
            <div class="bg-red-600 text-white rounded-lg p-6 mb-6 sticky top-24">
              <h3 class="text-xl font-bold mb-4">Warranty Support</h3>
              <div class="space-y-4 mb-6">
                <div class="flex items-center gap-3">
                  <Phone class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">(416) 555-0199</p>
                    <p class="text-sm opacity-90">Warranty hotline</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <FileText class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">Keep Your Papers</p>
                    <p class="text-sm opacity-90">Store warranty docs safely</p>
                  </div>
                </div>
              </div>
              <a href="/get-quote" class="block w-full bg-white text-red-600 text-center py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
                Get Warranty Quote
              </a>
            </div>

            <!-- Why Our Warranty Matters -->
            <div class="bg-white rounded-lg p-6 border border-gray-200 mb-6">
              <h4 class="font-bold text-gray-900 mb-4">Why This Matters</h4>
              <ul class="space-y-3 text-sm text-gray-700">
                <li class="flex items-start gap-2">
                  <CheckCircle class="w-4 h-4 text-green-600 mt-0.5" />
                  <span>Concrete is a major investment</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle class="w-4 h-4 text-green-600 mt-0.5" />
                  <span>Problems can appear years later</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle class="w-4 h-4 text-green-600 mt-0.5" />
                  <span>Repairs can be expensive</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle class="w-4 h-4 text-green-600 mt-0.5" />
                  <span>Many contractors disappear</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle class="w-4 h-4 text-green-600 mt-0.5" />
                  <span>We'll still be here in 25 years</span>
                </li>
              </ul>
            </div>

            <!-- Compare Warranties -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6">
              <h4 class="font-bold text-gray-900 mb-4">Compare Warranties</h4>
              <div class="space-y-3 text-sm">
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="text-gray-600">Toronto Concrete</span>
                  <span class="font-bold text-green-600">25 Years</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="text-gray-600">Typical Contractor</span>
                  <span class="text-gray-500">1-5 Years</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="text-gray-600">Handyman/Chuck</span>
                  <span class="text-gray-500">None</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">DIY</span>
                  <span class="text-gray-500">None</span>
                </div>
              </div>
            </div>

            <!-- Customer Story -->
            <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
              <h4 class="font-bold text-gray-900 mb-3">Warranty Success Story</h4>
              <p class="text-sm text-gray-700 italic mb-3">
                "Our driveway developed a crack 8 years after installation. One call to Joe, and his crew 
                was there within 2 days. Fixed it for free, no questions asked. Try getting that from 
                the guys with the pickup trucks going door-to-door."
              </p>
              <p class="text-sm font-semibold text-gray-600">
                - Maria S., North York
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="bg-gray-50 py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Warranty Questions</h2>
        <div class="max-w-3xl mx-auto space-y-4">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-2">Is the warranty transferable?</h3>
            <p class="text-gray-700">
              Yes! Our 25-year warranty automatically transfers to new owners if you sell your home. 
              The lifetime warranty option is also fully transferable.
            </p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-2">Do I need to register my warranty?</h3>
            <p class="text-gray-700">
              No registration needed. We keep all records. Just save your invoice and warranty certificate 
              we provide after completion.
            </p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-2">What if Toronto Concrete goes out of business?</h3>
            <p class="text-gray-700">
              We've been here 39 years and we're a family business - we're not going anywhere. But our 
              warranty is also backed by our insurance and bonding.
            </p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-2">How fast do you respond to warranty claims?</h3>
            <p class="text-gray-700">
              We inspect within 48 hours and if covered, typically complete repairs within 1 week. 
              Emergency issues are handled same-day.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-gray-900 text-white py-12">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Get Protected with Our 25-Year Warranty</h2>
        <p class="text-xl mb-8 text-gray-300">
          Quality work backed by the best warranty in Toronto
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:416-555-0199" class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
            Call: (416) 555-0199
          </a>
          <a href="/get-quote" class="bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Get Free Quote
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>