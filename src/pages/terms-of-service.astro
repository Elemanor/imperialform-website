---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="Terms of Service | Toronto Concrete">
  <Navigation />
  
  <main class="pt-24 pb-12">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-900 mb-6">Terms of Service</h1>
        <p class="text-sm text-gray-600 mb-8">Effective Date: January 1, 2024</p>
        
        <div class="prose prose-gray max-w-none">
          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">1. Agreement to Terms</h2>
            <p class="text-gray-700">
              By requesting a quote, hiring our services, or using our website, you agree to these 
              Terms of Service. If you disagree with any part, please do not use our services.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">2. Services</h2>
            <p class="text-gray-700 mb-3">
              Toronto Concrete provides concrete installation, repair, and maintenance services including:
            </p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Driveway installation and repair</li>
              <li>Patio and walkway construction</li>
              <li>Foundation repair and waterproofing</li>
              <li>Commercial concrete services</li>
              <li>Concrete maintenance and sealing</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">3. Quotes and Pricing</h2>
            <ul class="list-disc pl-6 text-gray-700 space-y-2">
              <li>All quotes are valid for 30 days from issue date</li>
              <li>Prices are subject to change based on site conditions discovered during work</li>
              <li>Additional work not included in original quote requires separate approval</li>
              <li>Quotes include all materials and labor unless otherwise specified</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">4. Payment Terms</h2>
            <ul class="list-disc pl-6 text-gray-700 space-y-2">
              <li>50% deposit required to schedule work</li>
              <li>Balance due upon completion</li>
              <li>Payment accepted by cash, check, or e-transfer</li>
              <li>Late payments subject to 2% monthly interest</li>
              <li>Customer responsible for any collection costs</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">5. Scheduling and Delays</h2>
            <ul class="list-disc pl-6 text-gray-700 space-y-2">
              <li>Work dates are approximate and weather-dependent</li>
              <li>We will notify you of any delays as soon as possible</li>
              <li>Customer-requested postponements may incur rescheduling fees</li>
              <li>Access to work area must be clear on scheduled dates</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">6. Warranty</h2>
            <p class="text-gray-700 mb-3">
              Our 25-year warranty covers:
            </p>
            <ul class="list-disc pl-6 text-gray-700 space-y-1">
              <li>Structural defects due to workmanship</li>
              <li>Material failures under normal use</li>
              <li>Issues specifically covered in warranty documentation</li>
            </ul>
            <p class="text-gray-700 mt-3">
              Warranty does not cover damage from abuse, acts of nature, or normal wear. See full 
              warranty terms for complete details.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">7. Customer Responsibilities</h2>
            <ul class="list-disc pl-6 text-gray-700 space-y-2">
              <li>Obtain necessary permits (unless we agree to handle)</li>
              <li>Mark private utilities before work begins</li>
              <li>Provide clear access to work area</li>
              <li>Follow curing and maintenance instructions</li>
              <li>Keep pets and children away from work area</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">8. Limitation of Liability</h2>
            <p class="text-gray-700">
              Our liability is limited to the contract value. We are not responsible for indirect, 
              consequential, or incidental damages. We maintain appropriate insurance and are fully 
              licensed and bonded.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">9. Cancellation Policy</h2>
            <ul class="list-disc pl-6 text-gray-700 space-y-2">
              <li>Cancellations more than 7 days before start: Full deposit refund</li>
              <li>Cancellations 3-7 days before start: 50% deposit refund</li>
              <li>Cancellations less than 3 days: No deposit refund</li>
              <li>Custom or special order materials are non-refundable</li>
            </ul>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">10. Dispute Resolution</h2>
            <p class="text-gray-700">
              Any disputes will first be addressed through good faith negotiation. If unresolved, 
              disputes will be settled through arbitration in Toronto, Ontario, Canada.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">11. Changes to Terms</h2>
            <p class="text-gray-700">
              We may update these terms periodically. Current terms apply to all new contracts. 
              Existing contracts remain under their original terms.
            </p>
          </section>

          <section class="mb-8">
            <h2 class="text-xl font-bold text-gray-900 mb-3">12. Contact Information</h2>
            <div class="text-gray-700">
              <p>Toronto Concrete</p>
              <p>Phone: (416) 555-0199</p>
              <p>Email: info@torontoconcrete.ca</p>
              <p>Address: North York, Toronto, ON</p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>