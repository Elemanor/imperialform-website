---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { CheckCircle, Phone, Calendar, DollarSign } from 'lucide-astro';
---

<Layout title="Concrete Patios Toronto | Stamped & Decorative | Toronto Concrete">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/services" class="hover:text-red-600">Services</a>
            <span>/</span>
            <span>Patios & Walkways</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Concrete Patios & Walkways
          </h1>
          <p class="text-xl text-gray-600">
            Transform your outdoor space with beautiful, durable concrete patios and walkways
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- Left Content -->
          <div class="lg:col-span-2">
            <!-- Main Image -->
            <img 
              src="https://images.unsplash.com/photo-1584738766473-61c083514bf4?w=800" 
              alt="Decorative concrete patio"
              class="w-full h-96 object-cover rounded-lg shadow-md mb-8"
            />

            <!-- Overview -->
            <div class="prose max-w-none mb-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">Create Your Perfect Outdoor Living Space</h2>
              <p class="text-gray-700 mb-4">
                A well-designed patio extends your living space outdoors, creating the perfect area for entertaining, 
                relaxing, or enjoying Toronto's beautiful summers. Whether you want a simple concrete pad or an 
                elaborate stamped concrete design that looks like natural stone, we can bring your vision to life.
              </p>
              <p class="text-gray-700 mb-4">
                Our concrete patios are built to withstand Toronto's climate extremes. We use proper base preparation, 
                reinforcement, and control joints to ensure your patio remains beautiful and crack-free for decades.
              </p>
              <p class="text-gray-700">
                From pool decks to garden walkways, outdoor kitchens to fire pit areas, we've created hundreds of 
                outdoor spaces that Toronto families love.
              </p>
            </div>

            <!-- Popular Patio Types -->
            <div class="bg-gray-50 rounded-lg p-8 mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Popular Patio Options</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1572297894736-0e3c8927883f?w=400" alt="Pool deck" class="w-full h-40 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Pool Decks</h4>
                  <p class="text-sm text-gray-600 mb-2">Non-slip textured surface, heat-resistant, chlorine-resistant sealers</p>
                  <p class="text-red-600 font-semibold text-sm">From $18/sq ft</p>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1584738766473-61c083514bf4?w=400" alt="Stamped patio" class="w-full h-40 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Stamped Patios</h4>
                  <p class="text-sm text-gray-600 mb-2">Patterns like flagstone, slate, brick - fraction of the cost</p>
                  <p class="text-red-600 font-semibold text-sm">From $20/sq ft</p>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400" alt="Walkways" class="w-full h-40 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Garden Walkways</h4>
                  <p class="text-sm text-gray-600 mb-2">Connect spaces beautifully, various widths and patterns</p>
                  <p class="text-red-600 font-semibold text-sm">From $15/sq ft</p>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?w=400" alt="Fire pit area" class="w-full h-40 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Fire Pit Areas</h4>
                  <p class="text-sm text-gray-600 mb-2">Heat-resistant concrete, custom shapes, built-in seating</p>
                  <p class="text-red-600 font-semibold text-sm">From $3,000</p>
                </div>
              </div>
            </div>

            <!-- Design Options -->
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Design & Finish Options</h3>
              <div class="bg-white rounded-lg border border-gray-200 p-6">
                <div class="grid md:grid-cols-2 gap-8">
                  <div>
                    <h4 class="font-bold text-gray-900 mb-3">Decorative Finishes</h4>
                    <ul class="space-y-2 text-gray-700">
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Stamped patterns (30+ options)</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Colored concrete (integral or stain)</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Exposed aggregate</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Acid staining</span>
                      </li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-900 mb-3">Functional Features</h4>
                    <ul class="space-y-2 text-gray-700">
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Built-in planters</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Seating walls</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Steps and levels</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                        <span>Drainage systems</span>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- Maintenance -->
            <div class="bg-red-50 rounded-lg p-8 mb-12 border-2 border-red-200">
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Easy Maintenance</h3>
              <p class="text-gray-700 mb-4">
                Our patios are designed for minimal maintenance. We seal all decorative concrete to protect against 
                stains, weather, and wear. With basic care, your patio will look great for decades:
              </p>
              <ul class="space-y-2 text-gray-700">
                <li>• Regular sweeping and occasional washing</li>
                <li>• Resealing every 2-3 years (we offer this service)</li>
                <li>• Prompt cleaning of spills</li>
                <li>• Snow removal without metal shovels</li>
              </ul>
            </div>

            <!-- Gallery -->
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Recent Patio Projects</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <img src="https://images.unsplash.com/photo-1584738766473-61c083514bf4?w=400" alt="Patio project 1" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1572297894736-0e3c8927883f?w=400" alt="Patio project 2" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400" alt="Patio project 3" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?w=400" alt="Patio project 4" class="w-full h-48 object-cover rounded-lg shadow-md" />
              </div>
            </div>
          </div>

          <!-- Right Sidebar -->
          <div class="lg:col-span-1">
            <!-- Quick Quote -->
            <div class="bg-red-600 text-white rounded-lg p-6 mb-6 sticky top-24">
              <h3 class="text-xl font-bold mb-4">Get Your Free Quote</h3>
              <div class="space-y-4 mb-6">
                <div class="flex items-center gap-3">
                  <Phone class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">(416) 555-0199</p>
                    <p class="text-sm opacity-90">Call for instant quote</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <Calendar class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">Free Design Consultation</p>
                    <p class="text-sm opacity-90">We help plan your space</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <DollarSign class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">Starting at $15/sq ft</p>
                    <p class="text-sm opacity-90">Transparent pricing</p>
                  </div>
                </div>
              </div>
              <a href="/get-quote" class="block w-full bg-white text-red-600 text-center py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
                Request Quote Online
              </a>
            </div>

            <!-- Customer Review -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6">
              <h4 class="font-bold text-gray-900 mb-3">What Customers Say</h4>
              <p class="text-gray-700 italic mb-3">
                "Joe designed and built our backyard patio with fire pit area. The stamped concrete looks exactly 
                like natural stone but costs way less. Best investment we made in our home!"
              </p>
              <p class="text-sm font-semibold text-gray-600">
                - The Andersons, North York
              </p>
            </div>

            <!-- Popular Add-ons -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h4 class="font-bold text-gray-900 mb-4">Popular Add-ons</h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li class="flex justify-between">
                  <span>Fire pit area</span>
                  <span class="text-red-600 font-semibold">+$3,000</span>
                </li>
                <li class="flex justify-between">
                  <span>Built-in BBQ pad</span>
                  <span class="text-red-600 font-semibold">+$1,500</span>
                </li>
                <li class="flex justify-between">
                  <span>Seating walls</span>
                  <span class="text-red-600 font-semibold">+$150/ft</span>
                </li>
                <li class="flex justify-between">
                  <span>Planters</span>
                  <span class="text-red-600 font-semibold">+$500</span>
                </li>
                <li class="flex justify-between">
                  <span>Lighting prep</span>
                  <span class="text-red-600 font-semibold">+$300</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-gray-900 text-white py-12">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Transform Your Backyard?</h2>
        <p class="text-xl mb-8 text-gray-300">
          Let's create the perfect outdoor living space for your family
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:416-555-0199" class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
            Call Now: (416) 555-0199
          </a>
          <a href="/get-quote" class="bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Get Design Consultation
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>