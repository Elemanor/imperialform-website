---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import { CheckCircle, Phone, Calendar, DollarSign } from 'lucide-astro';
---

<Layout title="Concrete Driveways Toronto | Installation & Replacement | Toronto Concrete">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gray-100 pt-24 pb-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl">
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <a href="/" class="hover:text-red-600">Home</a>
            <span>/</span>
            <a href="/services" class="hover:text-red-600">Services</a>
            <span>/</span>
            <span>Driveways</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Concrete Driveways in Toronto
          </h1>
          <p class="text-xl text-gray-600">
            Professional driveway installation, replacement, and repair services across the GTA
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-3 gap-12">
          <!-- Left Content -->
          <div class="lg:col-span-2">
            <!-- Main Image -->
            <img 
              src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800" 
              alt="Stamped concrete driveway in Toronto"
              class="w-full h-96 object-cover rounded-lg shadow-md mb-8"
            />

            <!-- Overview -->
            <div class="prose max-w-none mb-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">Quality Driveways That Last</h2>
              <p class="text-gray-700 mb-4">
                Your driveway is the first thing people see when they visit your home. It needs to look good, 
                but more importantly, it needs to withstand Toronto's harsh winters, heavy vehicles, and decades of use. 
                That's where we come in.
              </p>
              <p class="text-gray-700 mb-4">
                For nearly 40 years, Toronto Concrete has been installing and replacing driveways across the GTA. 
                We understand the unique challenges of our climate - the freeze-thaw cycles, road salt, and heavy snow 
                that can destroy poorly installed concrete.
              </p>
              <p class="text-gray-700">
                Whether you need a simple, functional driveway or want to enhance your curb appeal with stamped 
                or colored concrete, we have the experience and expertise to deliver results that last.
              </p>
            </div>

            <!-- Services -->
            <div class="bg-gray-50 rounded-lg p-8 mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Driveway Services We Offer</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">New Installations</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Complete excavation and base preparation</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Proper grading for water drainage</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Reinforced with rebar or wire mesh</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Control joints to prevent cracking</span>
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-3">Replacement & Repair</h4>
                  <ul class="space-y-2 text-gray-700">
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Complete removal of old driveway</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Crack repair and sealing</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Sunken section lifting</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
                      <span>Expansion joint replacement</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Finish Options -->
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Driveway Finish Options</h3>
              <div class="grid md:grid-cols-3 gap-4">
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=300" alt="Standard concrete" class="w-full h-32 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Standard Broom Finish</h4>
                  <p class="text-sm text-gray-600 mb-2">Classic, cost-effective option with good traction</p>
                  <p class="text-red-600 font-semibold text-sm">From $12/sq ft</p>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1572120360610-d971b9d7767c?w=300" alt="Stamped concrete" class="w-full h-32 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Stamped Concrete</h4>
                  <p class="text-sm text-gray-600 mb-2">Decorative patterns like stone, brick, or slate</p>
                  <p class="text-red-600 font-semibold text-sm">From $18/sq ft</p>
                </div>
                <div class="bg-white rounded-lg p-4 border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?w=300" alt="Exposed aggregate" class="w-full h-32 object-cover rounded mb-3" />
                  <h4 class="font-bold text-gray-900 mb-2">Exposed Aggregate</h4>
                  <p class="text-sm text-gray-600 mb-2">Decorative stones visible in surface</p>
                  <p class="text-red-600 font-semibold text-sm">From $15/sq ft</p>
                </div>
              </div>
            </div>

            <!-- Process -->
            <div class="bg-white rounded-lg border-2 border-red-600 p-8 mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Driveway Installation Process</h3>
              <div class="space-y-4">
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Free Consultation</h4>
                    <p class="text-gray-600">We visit your property, assess the project, and provide a detailed quote</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Excavation & Preparation</h4>
                    <p class="text-gray-600">Remove old concrete, excavate to proper depth, install gravel base</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Forms & Reinforcement</h4>
                    <p class="text-gray-600">Set forms to exact grade, install rebar or mesh for strength</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Pour & Finish</h4>
                    <p class="text-gray-600">Pour concrete, level, add finish texture, install control joints</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">5</div>
                  <div>
                    <h4 class="font-bold text-gray-900">Cure & Seal</h4>
                    <p class="text-gray-600">Allow proper curing time, apply sealer for protection</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Gallery -->
            <div class="mb-12">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">Recent Driveway Projects</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400" alt="Driveway project 1" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1572120360610-d971b9d7767c?w=400" alt="Driveway project 2" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1587582423116-ec07293f0395?w=400" alt="Driveway project 3" class="w-full h-48 object-cover rounded-lg shadow-md" />
                <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=400" alt="Driveway project 4" class="w-full h-48 object-cover rounded-lg shadow-md" />
              </div>
            </div>
          </div>

          <!-- Right Sidebar -->
          <div class="lg:col-span-1">
            <!-- Quick Quote -->
            <div class="bg-red-600 text-white rounded-lg p-6 mb-6 sticky top-24">
              <h3 class="text-xl font-bold mb-4">Get Your Free Quote</h3>
              <div class="space-y-4 mb-6">
                <div class="flex items-center gap-3">
                  <Phone class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">(416) 555-0199</p>
                    <p class="text-sm opacity-90">Call for instant quote</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <Calendar class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">Free Consultation</p>
                    <p class="text-sm opacity-90">On-site assessment</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <DollarSign class="w-5 h-5" />
                  <div>
                    <p class="font-semibold">Starting at $12/sq ft</p>
                    <p class="text-sm opacity-90">Competitive pricing</p>
                  </div>
                </div>
              </div>
              <a href="/get-quote" class="block w-full bg-white text-red-600 text-center py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
                Request Quote Online
              </a>
            </div>

            <!-- Why Choose Us -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6">
              <h4 class="font-bold text-gray-900 mb-4">Why Choose Us?</h4>
              <ul class="space-y-3 text-sm text-gray-700">
                <li class="flex items-start gap-2">
                  <span class="text-red-600">✓</span>
                  39 years serving Toronto
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600">✓</span>
                  25-year warranty on all work
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600">✓</span>
                  Licensed & insured
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600">✓</span>
                  Free detailed quotes
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-600">✓</span>
                  No deposits required
                </li>
              </ul>
            </div>

            <!-- Service Areas -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h4 class="font-bold text-gray-900 mb-4">Service Areas</h4>
              <p class="text-sm text-gray-600 mb-3">
                We install driveways throughout:
              </p>
              <div class="text-sm text-gray-700 space-y-1">
                <p>• Toronto (all boroughs)</p>
                <p>• North York</p>
                <p>• Scarborough</p>
                <p>• Etobicoke</p>
                <p>• Mississauga</p>
                <p>• Brampton</p>
                <p>• Vaughan</p>
                <p>• Richmond Hill</p>
                <p>• Markham</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-gray-900 text-white py-12">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Replace Your Driveway?</h2>
        <p class="text-xl mb-8 text-gray-300">
          Get a free, no-obligation quote from Toronto's trusted concrete contractors
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:416-555-0199" class="bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
            Call Now: (416) 555-0199
          </a>
          <a href="/get-quote" class="bg-white text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
            Get Online Quote
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>