---
const projects = [
  {
    title: "Stamped Driveway - Forest Hill",
    type: "Residential",
    image: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600",
    description: "Complete driveway replacement with stamped concrete pattern"
  },
  {
    title: "Pool Deck - Rosedale",
    type: "Residential",
    image: "https://images.unsplash.com/photo-1572297894736-0e3c8927883f?w=600",
    description: "Non-slip textured concrete around pool area"
  },
  {
    title: "Foundation Repair - Yorkville",
    type: "Residential",
    image: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=600",
    description: "Waterproofing and crack repair on 100-year old home"
  },
  {
    title: "Parking Lot - Mississauga",
    type: "Commercial",
    image: "https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=600",
    description: "10,000 sq ft commercial parking lot"
  },
  {
    title: "Decorative Patio - High Park",
    type: "Residential",
    image: "https://images.unsplash.com/photo-1584738766473-61c083514bf4?w=600",
    description: "Acid-stained concrete patio with built-in planters"
  },
  {
    title: "Garage Floor - Brampton",
    type: "Residential",
    image: "https://images.unsplash.com/photo-1565610222536-ef125c59da2e?w=600",
    description: "Epoxy coating over polished concrete"
  }
];
---

<section id="projects" class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Recent Projects
        </h2>
        <p class="text-lg text-gray-600">
          Some of our recent work around Toronto and the GTA
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {projects.map((project) => (
          <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-48 object-cover"
            />
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-1 rounded">
                  {project.type}
                </span>
              </div>
              <h3 class="font-bold text-gray-900 mb-2">{project.title}</h3>
              <p class="text-sm text-gray-600">{project.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="bg-white rounded-lg p-8 shadow-md text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Want to See More?
        </h3>
        <p class="text-gray-600 mb-6">
          We have hundreds of completed projects across the GTA. 
          Call us to see examples specific to your project type.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:416-555-0199" class="bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors">
            Call: (416) 555-0199
          </a>
          <a href="#contact" class="bg-gray-200 text-gray-900 px-6 py-3 rounded-lg font-semibold hover:bg-gray-300 transition-colors">
            Get Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>
</section>