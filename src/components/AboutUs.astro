---
import { Users, Award, Clock, Hammer } from 'lucide-astro';
---

<section id="about" class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          About Toronto Concrete
        </h2>
        <p class="text-lg text-gray-600">
          Three generations of quality concrete work in the GTA
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Left - Our Story -->
        <div>
          <div class="bg-white rounded-lg p-6 shadow-md mb-6">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Our Story</h3>
            <p class="text-gray-700 mb-4">
              Toronto Concrete started in 1985 when Giuseppe Torretti emigrated from Italy with nothing but his tools and a dream. He began doing small concrete repairs in the neighborhood, and word quickly spread about his attention to detail and fair prices.
            </p>
            <p class="text-gray-700 mb-4">
              Today, his son Joe Jr. and grandson Michael run the business with the same values: honest work, fair pricing, and treating every customer like family. We're not the biggest company, but we believe we're the best at what we do.
            </p>
            <p class="text-gray-700">
              We still serve many of the same families we worked for 30 years ago - their kids now call us for their homes. That's the kind of trust you can't buy; you have to earn it one job at a time.
            </p>
          </div>
          
          <!-- Family photo -->
          <div class="relative rounded-lg overflow-hidden shadow-md">
            <img 
              src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600" 
              alt="Three generations of our family business"
              class="w-full h-64 object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-black/60 text-white p-4">
              <p class="text-sm">Giuseppe, Joe Jr., and Michael Torretti - Three generations of expertise</p>
            </div>
          </div>
        </div>

        <!-- Right - Why Choose Us -->
        <div>
          <!-- Key stats -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-white rounded-lg p-4 text-center shadow-md">
              <Clock class="w-8 h-8 text-red-600 mx-auto mb-2" />
              <div class="text-2xl font-bold text-gray-900">39</div>
              <div class="text-sm text-gray-600">Years Experience</div>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-md">
              <Users class="w-8 h-8 text-red-600 mx-auto mb-2" />
              <div class="text-2xl font-bold text-gray-900">5000+</div>
              <div class="text-sm text-gray-600">Projects Done</div>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-md">
              <Award class="w-8 h-8 text-red-600 mx-auto mb-2" />
              <div class="text-2xl font-bold text-gray-900">A+</div>
              <div class="text-sm text-gray-600">BBB Rating</div>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow-md">
              <Hammer class="w-8 h-8 text-red-600 mx-auto mb-2" />
              <div class="text-2xl font-bold text-gray-900">100%</div>
              <div class="text-sm text-gray-600">Licensed & Insured</div>
            </div>
          </div>

          <!-- What makes us different -->
          <div class="bg-white rounded-lg p-6 shadow-md">
            <h3 class="text-xl font-bold text-gray-900 mb-4">What Makes Us Different</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 bg-red-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-white text-xs">✓</span>
                </span>
                <div>
                  <strong class="text-gray-900">We show up on time</strong>
                  <p class="text-sm text-gray-600">If we say 8 AM, we're there at 8 AM. Period.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 bg-red-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-white text-xs">✓</span>
                </span>
                <div>
                  <strong class="text-gray-900">No surprise costs</strong>
                  <p class="text-sm text-gray-600">Our quote is our price. No hidden fees, ever.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 bg-red-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-white text-xs">✓</span>
                </span>
                <div>
                  <strong class="text-gray-900">We clean up after ourselves</strong>
                  <p class="text-sm text-gray-600">Your property will be cleaner than when we arrived.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 bg-red-600 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-white text-xs">✓</span>
                </span>
                <div>
                  <strong class="text-gray-900">We stand behind our work</strong>
                  <p class="text-sm text-gray-600">25-year warranty because we do it right the first time.</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Testimonial -->
          <div class="bg-red-50 rounded-lg p-6 mt-6 border-l-4 border-red-600">
            <p class="text-gray-700 italic mb-3">
              "Joe and his crew did our driveway 5 years ago. Still looks brand new. They were the only contractor who actually showed up for the quote when they said they would. Fair price, great work, nice people."
            </p>
            <p class="text-sm text-gray-600 font-semibold">
              - Maria S., Forest Hill
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>