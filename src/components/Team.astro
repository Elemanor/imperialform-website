---
import { Award, Hammer, HardHat, Users } from 'lucide-astro';

const teamMembers = [
  {
    name: "Giuseppe Torretti Jr.",
    role: "President & CEO",
    image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400",
    experience: "25+ Years",
    specialty: "Business Development",
    bio: "Second generation leader carrying on the family tradition of excellence."
  },
  {
    name: "Marco Torretti",
    role: "VP Operations", 
    image: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=400",
    experience: "20+ Years",
    specialty: "Project Management",
    bio: "Oversees all major projects ensuring quality and timeline adherence."
  },
  {
    name: "Anthony Romano",
    role: "Head Foreman",
    image: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400",
    experience: "30+ Years",
    specialty: "Decorative Concrete",
    bio: "Master craftsman specializing in stamped and decorative finishes."
  },
  {
    name: "Michael O'Brien",
    role: "Senior Estimator",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400",
    experience: "15+ Years",
    specialty: "Commercial Projects",
    bio: "Provides accurate, transparent quotes for projects of all sizes."
  },
  {
    name: "Sofia Martinez",
    role: "Quality Control Manager",
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400",
    experience: "12+ Years",
    specialty: "Standards & Safety",
    bio: "Ensures every project meets our high standards and safety requirements."
  },
  {
    name: "James Chen",
    role: "Lead Technician",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400",
    experience: "18+ Years",
    specialty: "Foundation Systems",
    bio: "Expert in foundation repair and waterproofing solutions."
  }
];
---

<section id="team" class="py-24 relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1920" alt="Background" class="w-full h-full object-cover" />
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-block bg-red-600 text-white px-6 py-2 rounded-full text-sm font-semibold mb-4">
        <Users class="inline w-4 h-4 mr-2" />
        Meet Our Experts
      </div>
      <h2 class="text-5xl md:text-6xl font-black text-white mb-6">
        The <span class="text-red-500">Faces</span> Behind Your Project
        <span class="block text-3xl md:text-4xl mt-2 font-light text-gray-300">Skilled Professionals You Can Trust</span>
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Our team combines decades of experience with cutting-edge techniques to deliver exceptional results on every project.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {teamMembers.map((member) => (
        <div class="group relative">
          <div class="relative overflow-hidden rounded-3xl bg-white shadow-2xl hover:shadow-3xl transition-all duration-300">
            <!-- Image Container -->
            <div class="relative h-80 overflow-hidden">
              <img 
                src={member.image} 
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
              
              <!-- Experience Badge -->
              <div class="absolute top-4 right-4 bg-red-600 text-white px-3 py-1 rounded-full text-sm font-semibold">
                {member.experience}
              </div>
              
              <!-- Name Overlay -->
              <div class="absolute bottom-4 left-4 right-4 text-white">
                <h3 class="text-2xl font-bold mb-1">{member.name}</h3>
                <p class="text-red-400 font-semibold">{member.role}</p>
              </div>
            </div>
            
            <!-- Content -->
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <HardHat class="w-5 h-5 text-red-600" />
                <span class="text-sm font-semibold text-gray-700">{member.specialty}</span>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed">
                {member.bio}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Team Stats -->
    <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
      <div class="grid md:grid-cols-4 gap-8 text-center text-white">
        <div>
          <Hammer class="w-10 h-10 text-red-500 mx-auto mb-3" />
          <div class="text-3xl font-bold mb-1">150+</div>
          <p class="text-gray-300">Combined Years Experience</p>
        </div>
        <div>
          <Award class="w-10 h-10 text-red-500 mx-auto mb-3" />
          <div class="text-3xl font-bold mb-1">45+</div>
          <p class="text-gray-300">Certified Professionals</p>
        </div>
        <div>
          <Users class="w-10 h-10 text-red-500 mx-auto mb-3" />
          <div class="text-3xl font-bold mb-1">3</div>
          <p class="text-gray-300">Generations of Expertise</p>
        </div>
        <div>
          <HardHat class="w-10 h-10 text-red-500 mx-auto mb-3" />
          <div class="text-3xl font-bold mb-1">100%</div>
          <p class="text-gray-300">Safety Certified</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <p class="text-xl text-gray-300 mb-6">
        Ready to work with Toronto's most experienced concrete team?
      </p>
      <a href="#contact" class="inline-block bg-red-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-red-700 transition-colors shadow-xl">
        Start Your Project Today
      </a>
    </div>
  </div>
</section>